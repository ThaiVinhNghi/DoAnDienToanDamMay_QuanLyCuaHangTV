<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; }
        .img-detail { width: 100%; height: auto; max-height: 400px; object-fit: contain; }
        .card-tv:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); transition: 0.3s; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <%- include('navbar') %>

    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none"><%= sanpham.LoaiSanPham ? sanpham.LoaiSanPham.TenLoai : 'Tivi' %></a></li>
                <li class="breadcrumb-item active" aria-current="page"><%= sanpham.TenSP %></li>
            </ol>
        </nav>
    </div>

    <div class="container flex-grow-1 mb-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden p-4">
            <div class="row g-5">
                <div class="col-md-5 text-center">
                    <img src="/images/<%= sanpham.HinhAnh %>" alt="<%= sanpham.TenSP %>" class="img-detail rounded bg-white p-3 border">
                </div>

                <div class="col-md-7">
                    <span class="badge bg-primary fs-6 mb-2"><%= sanpham.HangSanXuat ? sanpham.HangSanXuat.TenHang : 'N/A' %></span>
                    
                    <h2 class="fw-bold text-dark mb-3"><%= sanpham.TenSP %></h2>
                    
                    <h3 class="text-danger fw-bold mb-4"><%= sanpham.GiaBan.toLocaleString('vi-VN') %> đ</h3>

                    <div class="mb-4">
                        <% if(sanpham.SoLuongTon > 0) { %>
                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Còn hàng (<%= sanpham.SoLuongTon %> sản phẩm)</span>
                        <% } else { %>
                            <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill"></i> Đã hết hàng</span>
                        <% } %>
                    </div>

                    <div class="mb-4">
                        <% if(sanpham.SoLuongTon > 0) { %>
                            <a href="/themvaogio/<%= sanpham._id %>" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi bi-cart-plus"></i> THÊM VÀO GIỎ HÀNG
                            </a>
                        <% } else { %>
                            <button class="btn btn-secondary btn-lg rounded-pill px-5 fw-bold" disabled>
                                KHÔNG THỂ MUA
                            </button>
                        <% } %>
                    </div>

                    <h5 class="fw-bold border-bottom pb-2 mt-4">Mô tả sản phẩm</h5>
                    <p class="text-muted" style="white-space: pre-line;"><%= sanpham.MoTa %></p>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4 mt-5 bg-white">
            <h4 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-star-fill text-warning me-2"></i>Đánh giá từ khách hàng</h4>

            <% if (khachhang) { %>
                <form action="/danhgia/<%= sanpham._id %>" method="POST" class="mb-5 bg-light p-4 rounded-3 border">
                    <h6 class="fw-bold mb-3">Bạn chấm sản phẩm này mấy sao?</h6>
                    <div class="mb-3">
                        <div class="btn-group" role="group">
                            <input type="radio" class="btn-check" name="SoSao" id="sao5" value="5" checked>
                            <label class="btn btn-outline-warning fw-bold" for="sao5">5 <i class="bi bi-star-fill"></i></label>

                            <input type="radio" class="btn-check" name="SoSao" id="sao4" value="4">
                            <label class="btn btn-outline-warning fw-bold" for="sao4">4 <i class="bi bi-star-fill"></i></label>

                            <input type="radio" class="btn-check" name="SoSao" id="sao3" value="3">
                            <label class="btn btn-outline-warning fw-bold" for="sao3">3 <i class="bi bi-star-fill"></i></label>
                            
                            <input type="radio" class="btn-check" name="SoSao" id="sao2" value="2">
                            <label class="btn btn-outline-warning fw-bold" for="sao2">2 <i class="bi bi-star-fill"></i></label>

                            <input type="radio" class="btn-check" name="SoSao" id="sao1" value="1">
                            <label class="btn btn-outline-warning fw-bold" for="sao1">1 <i class="bi bi-star-fill"></i></label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <textarea name="BinhLuan" class="form-control" rows="3" placeholder="Chia sẻ trải nghiệm của bạn về chiếc Tivi này..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary fw-bold px-4 rounded-pill">Gửi đánh giá</button>
                </form>
            <% } else { %>
                <div class="alert alert-warning fw-bold">
                    <i class="bi bi-exclamation-circle"></i> Vui lòng <a href="/dangnhap" class="text-danger text-decoration-underline">Đăng nhập</a> để để lại đánh giá của bạn!
                </div>
            <% } %>

            <div class="review-list">
                <% if(sanpham.DanhGia && sanpham.DanhGia.length > 0) { %>
                    <% sanpham.DanhGia.reverse().forEach(dg => { %>
                        <div class="d-flex mb-4 pb-3 border-bottom">
                            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center fw-bold me-3 shadow-sm" style="width: 45px; height: 45px; font-size: 1.2rem;">
                                <%= dg.KhachHang ? dg.KhachHang.HoVaTen.charAt(0).toUpperCase() : 'K' %>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1"><%= dg.KhachHang ? dg.KhachHang.HoVaTen : 'Khách hàng ẩn danh' %></h6>
                                <div class="text-warning mb-2" style="font-size: 0.9rem;">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="bi <%= i <= dg.SoSao ? 'bi-star-fill' : 'bi-star' %>"></i>
                                    <% } %>
                                    <span class="text-muted ms-2 small"><%= new Date(dg.NgayDanhGia).toLocaleDateString('vi-VN') %></span>
                                </div>
                                <p class="mb-0 text-secondary"><%= dg.BinhLuan %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted fst-italic">Chưa có đánh giá nào. Hãy trở thành người đầu tiên đánh giá sản phẩm này!</p>
                <% } %>
            </div>
        </div>
        <% if(splienquan.length > 0) { %>
            <h4 class="fw-bold mt-5 mb-4 border-bottom pb-2">Sản phẩm cùng loại</h4>
            <div class="row row-cols-1 row-cols-md-4 g-4">
                <% splienquan.forEach(sp => { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm card-tv rounded-4 p-3 text-center">
                            <a href="/sanpham/<%= sp._id %>" class="text-decoration-none">
                                <img src="/images/<%= sp.HinhAnh %>" class="card-img-top mx-auto" style="height: 150px; object-fit: contain;" alt="<%= sp.TenSP %>">
                                <div class="card-body p-2">
                                    <h6 class="card-title fw-bold text-dark text-truncate" title="<%= sp.TenSP %>"><%= sp.TenSP %></h6>
                                    
                                    <% 
                                        let tbSaoLienQuan = 0; let soDGLienQuan = 0;
                                        if(sp.DanhGia && sp.DanhGia.length > 0) {
                                            soDGLienQuan = sp.DanhGia.length;
                                            let tongSao = sp.DanhGia.reduce((sum, dg) => sum + dg.SoSao, 0);
                                            tbSaoLienQuan = (tongSao / soDGLienQuan).toFixed(1);
                                        }
                                    %>
                                    <div class="mb-2 text-center" style="font-size: 13px;">
                                        <span class="text-warning fw-bold"><i class="bi bi-star-fill"></i> <%= tbSaoLienQuan > 0 ? tbSaoLienQuan : 'Chưa có' %></span>
                                        <% if(soDGLienQuan > 0) { %>
                                            <span class="text-muted ms-1">(<%= soDGLienQuan %>)</span>
                                        <% } %>
                                    </div>

                                    <p class="card-text text-danger fw-bold mb-0"><%= sp.GiaBan.toLocaleString('vi-VN') %> đ</p>
                                </div>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>