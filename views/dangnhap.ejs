<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#eff6ff', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' }
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-slate-900 flex flex-col justify-center items-center py-12 sm:px-6 lg:px-8 relative">

    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=80"
            class="w-full h-full object-cover opacity-30" alt="Server Background">
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/80 to-slate-900"></div>
    </div>

    <div class="z-10 w-full max-w-md mx-auto px-4">

        <div class="text-center mb-10">
            <div
                class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 shadow-xl shadow-brand-500/40 mb-6 border border-white/10">
                <i class="bi bi-shield-lock text-4xl text-white"></i>
            </div>
            <h2 class="text-center text-4xl font-extrabold text-white tracking-tight mb-2 drop-shadow-md">
                Admin <span class="text-brand-400">Portal</span>
            </h2>
            <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-widest">
                Hệ thống Quản trị Nội bộ TVN Store
            </p>
        </div>

        <div
            class="bg-slate-800/60 backdrop-blur-xl py-10 px-8 shadow-2xl rounded-[2rem] border border-white/10 relative overflow-hidden">

            <div class="absolute -top-24 -left-24 w-48 h-48 bg-brand-500/30 rounded-full blur-3xl pointer-events-none">
            </div>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="bg-red-500/10 border border-red-500/50 p-4 mb-8 rounded-xl flex items-center">
                    <i class="bi bi-exclamation-triangle text-red-400 mr-3 text-xl"></i>
                    <p class="text-sm text-red-200 font-semibold">
                        <%= error %>
                    </p>
                </div>
                <% } %>

                    <form class="space-y-6 relative z-10" action="/admin/dangnhap" method="POST">

                        <div>
                            <label for="TenDangNhap"
                                class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-wide">Tên đăng
                                nhập</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="bi bi-person text-slate-500 text-lg"></i>
                                </div>
                                <input id="TenDangNhap" name="TenDangNhap" type="text" required autofocus
                                    class="block w-full pl-12 pr-4 py-3.5 bg-slate-900/50 border border-white/10 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-white placeholder-slate-500 transition-all outline-none text-base"
                                    placeholder="admin_tvn">
                            </div>
                        </div>

                        <div>
                            <label for="MatKhau"
                                class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-wide">Mật
                                khẩu</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="bi bi-key text-slate-500 text-lg"></i>
                                </div>
                                <input id="MatKhau" name="MatKhau" type="password" required
                                    class="block w-full pl-12 pr-4 py-3.5 bg-slate-900/50 border border-white/10 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 text-white placeholder-slate-500 transition-all outline-none text-base"
                                    placeholder="••••••••">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full flex justify-center items-center py-4 px-4 border border-transparent rounded-xl shadow-lg text-base font-extrabold text-white bg-brand-600 hover:bg-brand-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-brand-500 transition-all transform hover:-translate-y-1 mt-8">
                            <i class="bi bi-box-arrow-in-right mr-2 text-xl"></i> XÁC THỰC QUYỀN TRUY CẬP
                        </button>
                    </form>

                    <div class="mt-8 border-t border-white/10 pt-6">
                        <a href="/"
                            class="group flex items-center justify-center text-sm font-medium text-slate-500 hover:text-white transition-colors">
                            <i class="bi bi-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i> Thoát
                            về trang Cửa hàng
                        </a>
                    </div>
        </div>
    </div>

    <div class="absolute bottom-6 text-center w-full z-10">
        <p class="text-xs text-slate-500 font-medium tracking-wide">
            &copy; 2026 TVN Store. Đồ án Điện toán đám mây.
        </p>
    </div>

</body>

</html>