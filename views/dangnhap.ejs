<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #1e1e2d; /* Nền tối */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .admin-login-card {
            background: #1a1a27;
            border: 1px solid #2b2b40;
            border-radius: 20px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 450px;
            padding: 3rem 2.5rem;
        }
        .form-control { 
            background: #151521; 
            border: 1px solid #2b2b40; 
            color: #fff; 
            border-radius: 12px; 
            padding: 12px 20px; 
        }
        .form-control:focus { 
            background: #151521; 
            border-color: #3699ff; 
            color: #fff; 
            box-shadow: 0 0 0 4px rgba(54, 153, 255, 0.1); 
        }
        .form-control::placeholder { color: #565674; }
        
        .form-label { color: #a2a3b7; font-weight: 500; font-size: 0.95rem; }
        .input-group-text { background: #151521; border-color: #2b2b40; color: #a2a3b7; }
        
        .btn-admin { 
            background: #3699ff; 
            border: none; 
            border-radius: 12px; 
            padding: 12px; 
            font-weight: 700; 
            transition: all 0.3s;
        }
        .btn-admin:hover { background: #187de4; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(54, 153, 255, 0.3); }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center px-3">
        <div class="admin-login-card">
            <div class="text-center mb-4">
                <div class="bg-dark rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow" style="width: 80px; height: 80px; border: 2px solid #3699ff;">
                    <i class="bi bi-shield-lock-fill text-primary" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="text-white fw-bolder mb-1">QUẢN TRỊ HỆ THỐNG</h3>
                <p style="color: #a2a3b7;">Đăng nhập để vào TVN Admin</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert bg-danger text-white border-0 rounded-3 fw-bold text-center mb-4"><i class="bi bi-shield-x me-2"></i><%= error %></div>
            <% } %>

            <form action="/admin/dangnhap" method="POST">
                <div class="mb-4">
                    <label class="form-label">Tài khoản Quản trị</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="bi bi-person-fill"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" name="TenDangNhap" required autofocus placeholder="Nhập username">
                    </div>
                </div>
                <div class="mb-5">
                    <label class="form-label">Mật mã bảo mật</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="bi bi-key-fill"></i></span>
                        <input type="password" class="form-control border-start-0 ps-0" name="MatKhau" required placeholder="Nhập password">
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary btn-admin w-100 text-white">
                    XÁC THỰC QUYỀN TRUY CẬP <i class="bi bi-arrow-right-short ms-1 fs-5 align-middle"></i>
                </button>
            </form>
            
            <div class="text-center mt-4">
                <a href="/" class="text-decoration-none" style="color: #565674; font-size: 0.9rem;">
                    <i class="bi bi-house-door-fill me-1"></i> Trở về Trang Khách Hàng
                </a>
            </div>
        </div>
    </div>
</body>
</html>