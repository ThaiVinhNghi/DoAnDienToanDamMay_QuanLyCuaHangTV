<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#fff0f0', 100: '#fecaca', 200: '#fca5a5', 500: '#dc2626', 600: '#b91c1c', 700: '#991b1b', 800: '#7f1d1d' } }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-slate-50 flex flex-col font-sans">

    <%- include('navbar') %>

        <div class="flex-grow flex items-center justify-center py-10 px-4">
            <div class="bg-white rounded-3xl shadow-xl w-full max-w-3xl overflow-hidden border border-slate-100">

                <div class="bg-brand-600 text-white py-6 text-center">
                    <h2 class="text-2xl font-bold flex items-center justify-center">
                        <i class="bi bi-person-plus mr-2"></i> Đăng ký Tài khoản TVN
                    </h2>
                    <p class="text-brand-100 text-sm mt-1">Tạo tài khoản để quản lý đơn hàng và nhận ưu đãi</p>
                </div>

                <div class="p-8 sm:p-10">
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg flex items-center">
                            <i class="bi bi-exclamation-circle-fill text-red-500 mr-3 text-lg"></i>
                            <p class="text-sm text-red-700 font-semibold">
                                <%= error %>
                            </p>
                        </div>
                        <% } %>

                            <form action="/dangky" method="POST">

                                <div class="mb-8">
                                    <h3
                                        class="text-lg font-bold text-slate-800 border-b border-slate-200 pb-2 mb-5 flex items-center">
                                        <i class="bi bi-house-door text-brand-500 mr-2"></i> Thông tin giao hàng
                                    </h3>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                        <div>
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Họ và
                                                tên</label>
                                            <input type="text" name="HoVaTen" required
                                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                placeholder="Nguyễn Văn A">
                                        </div>
                                        <div>
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Số điện
                                                thoại</label>
                                            <input type="text" name="SoDienThoai" required
                                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                placeholder="0912345678">
                                        </div>
                                        <div class="sm:col-span-2">
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Địa chỉ giao
                                                hàng chi tiết</label>
                                            <input type="text" name="DiaChi" required
                                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                placeholder="Số nhà, Đường, Phường/Xã, Quận/Huyện...">
                                        </div>
                                        <div class="sm:col-span-2">
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Email <span
                                                    class="text-slate-400 font-normal">(Tùy chọn)</span></label>
                                            <input type="email" name="Email"
                                                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                placeholder="email@example.com">
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-8">
                                    <h3
                                        class="text-lg font-bold text-slate-800 border-b border-slate-200 pb-2 mb-5 flex items-center">
                                        <i class="bi bi-shield-lock text-brand-500 mr-2"></i> Thông tin bảo mật
                                    </h3>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                        <div>
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Tên đăng
                                                nhập</label>
                                            <div class="relative">
                                                <div
                                                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <i class="bi bi-person text-slate-400"></i>
                                                </div>
                                                <input type="text" name="TenDangNhap" required
                                                    class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                    placeholder="Tài khoản...">
                                            </div>
                                        </div>
                                        <div>
                                            <label class="block text-sm font-semibold text-slate-700 mb-1">Mật
                                                khẩu</label>
                                            <div class="relative">
                                                <div
                                                    class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <i class="bi bi-key text-slate-400"></i>
                                                </div>
                                                <input type="password" name="MatKhau" required
                                                    class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                                    placeholder="••••••••">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <button type="submit"
                                    class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-emerald-500/30 transition-all hover:-translate-y-0.5 text-lg">
                                    Hoàn Tất Đăng Ký
                                </button>

                                <p class="mt-6 text-center text-sm text-slate-600">
                                    Đã có tài khoản?
                                    <a href="/dangnhap"
                                        class="font-bold text-brand-600 hover:text-brand-700 transition-colors">Đăng
                                        nhập tại đây</a>
                                </p>
                            </form>
                </div>
            </div>
        </div>

        <%- include('footer') %>
</body>

</html>