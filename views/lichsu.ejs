<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#eff6ff', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' } } } } }
    </script>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

        <div class="container mx-auto px-4 mt-8 mb-16 flex-grow max-w-5xl">
            <h2 class="text-3xl font-extrabold text-slate-900 mb-8"><i
                    class="bi bi-clock-history text-brand-600 mr-2"></i>Lịch Sử Mua Hàng</h2>

            <% if(hoadon && hoadon.length> 0) { %>
                <div class="flex flex-col gap-8">
                    <% hoadon.forEach(hd=> { %>
                        <div class="bg-white rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-100 overflow-hidden flex flex-col relative group">
                            <!-- Hiệu ứng dải màu -->
                            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-brand-400 to-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            
                            <div class="bg-gradient-to-br from-slate-50 to-white px-8 py-5 flex flex-col lg:flex-row justify-between items-start lg:items-center border-b border-slate-100 gap-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-brand-100 text-brand-600 p-2.5 rounded-xl">
                                        <i class="bi bi-receipt-cutoff text-xl"></i>
                                    </div>
                                    <div>
                                        <span class="text-slate-400 text-xs font-bold uppercase tracking-wider block mb-0.5">Mã Giao Dịch</span>
                                        <span class="font-black text-slate-800 text-lg tracking-tight">#<%= hd._id.toString().slice(-6).toUpperCase() %></span>
                                    </div>
                                </div>
                                <div class="flex flex-wrap items-center gap-2">                                 <% if (hd.TrangThai==='Chờ duyệt') { %>
                                    <span class="bg-amber-100 text-amber-700 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center">
                                        <i class="bi bi-hourglass-split mr-1.5 animate-[spin_3s_linear_infinite]"></i> Đang chờ duyệt
                                    </span>
                                <% } else if (hd.TrangThai==='Từ chối' || hd.TrangThai==='Đã hủy') { %>
                                    <span class="bg-red-100 text-red-700 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center">
                                        <i class="bi bi-x-circle-fill mr-1.5"></i> Đã hủy / Từ chối
                                    </span>
                                <% } else if (hd.HinhThucThanhToan === 'Trả góp' && hd.TraGopInfo && hd.TraGopInfo.TrangThai !== 'Đã tất toán') { %>
                                        <%
                                            let tgThang = hd.TraGopInfo.SoThang || 0;
                                            let tgDaTra = hd.TraGopInfo.SoThangDaTra || 0;
                                            let tgTrangThai = hd.TraGopInfo.TrangThai || 'Đang trả';
                                            let badgeClass = tgTrangThai === 'Nợ xấu' ? 'bg-red-100 text-red-700' : tgTrangThai === 'Quá hạn' ? 'bg-orange-100 text-orange-700' : 'bg-blue-100 text-blue-700';
                                            let badgeIcon = tgTrangThai === 'Nợ xấu' ? 'bi-exclamation-triangle-fill' : 'bi-credit-card-2-front';
                                        %>
                                        <span class="<%= badgeClass %> font-bold px-3 py-1.5 rounded-lg text-sm flex items-center">
                                            <i class="bi <%= badgeIcon %> mr-1.5"></i>
                                            Trả góp: <%= tgDaTra %>/<%= tgThang %> tháng (<%= tgTrangThai %>)
                                        </span>
                                    <% } else if (hd.YeuCauDoiTra) { %>
                                        <% if (hd.YeuCauDoiTra.TrangThai==='Đã xử lý' ||
                                            hd.YeuCauDoiTra.TrangThai==='Đã duyệt' ) { %>
                                            <span
                                                class="bg-blue-100 text-blue-700 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center shadow-sm border border-blue-200">
                                                <i class="bi bi-check-all mr-1.5 text-lg"></i>
                                                <%= hd.YeuCauDoiTra.LoaiYeuCau==='Trả hàng' ? 'Đã Hoàn Trả Tiền'
                                                    : 'Đã Đổi Tivi Mới' %>
                                            </span>
                                            <% } else if (hd.YeuCauDoiTra.TrangThai==='Từ chối' ) { %>
                                                <span
                                                    class="bg-red-50 text-red-600 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center border border-red-100">
                                                    <i class="bi bi-x-circle mr-1.5"></i> Từ chối Đổi/Trả
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        class="bg-amber-100 text-amber-700 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center">
                                                        <i
                                                            class="bi bi-arrow-repeat mr-1.5 animate-[spin_3s_linear_infinite]"></i>
                                                        Đang xử lý Đổi/Trả
                                                    </span>
                                                    <% } %>
                                                        <% } else { %>
                                                            <span
                                                                class="bg-emerald-100 text-emerald-700 font-bold px-3 py-1.5 rounded-lg text-sm flex items-center">
                                                                <i class="bi bi-check-circle-fill mr-1.5"></i> Đã thanh
                                                                toán
                                                            </span>
                                                            <% } %>
                                </div>
                            </div>

                            <div class="divide-y divide-slate-100">
                                <% hd.ChiTietHoaDon.forEach(item=> { %>
                                    <% if (item.SanPham) { %>
                                        <div class="px-8 py-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 hover:bg-slate-50/50 transition-colors">
                                            <div class="flex items-center gap-5 flex-1 relative w-full">
                                                <% let img=item.SanPham.HinhAnh.startsWith('http') ? item.SanPham.HinhAnh : '/images/' + item.SanPham.HinhAnh; %>
                                                <div class="relative flex-shrink-0">
                                                    <img src="<%= img %>" alt="<%= item.SanPham.TenSP %>" class="w-28 h-28 object-contain bg-white rounded-2xl border border-slate-200 p-3 shadow-sm hover:shadow-md transition-shadow">
                                                    <span class="absolute -top-3 -right-3 bg-slate-800 text-white text-xs font-bold w-8 h-8 flex items-center justify-center rounded-full shadow-lg border-2 border-white"><%= item.SoLuong %></span>
                                                </div>
                                                <div class="flex-1">
                                                    <h5 class="font-extrabold text-slate-800 text-xl font-sans tracking-tight mb-2 line-clamp-2"><%= item.SanPham.TenSP %></h5>
                                                    <div class="flex items-baseline gap-2">
                                                        <span class="text-brand-600 font-extrabold text-xl"><%= item.DonGiaBan ? item.DonGiaBan.toLocaleString('vi-VN') : item.SanPham.GiaBan.toLocaleString('vi-VN') %> <span class="text-sm underline">đ</span></span>
                                                    </div>

                                                        <% if (hd.YeuCauDoiTra && hd.YeuCauDoiTra.LoaiYeuCau === 'Đổi hàng' && (hd.YeuCauDoiTra.TrangThai === 'Đã xử lý' || hd.YeuCauDoiTra.TrangThai === 'Đã duyệt')) { %>
                                                            <div class="mt-2.5 text-sm text-brand-700 bg-brand-50 border border-brand-100 p-2 rounded-lg font-bold flex items-center w-max">
                                                                <i class="bi bi-arrow-repeat mr-2"></i>
                                                                Đã đổi qua: <%= hd.YeuCauDoiTra.SanPhamMoi && hd.YeuCauDoiTra.SanPhamMoi.length > 0 && hd.YeuCauDoiTra.SanPhamMoi[0].SanPham ? hd.YeuCauDoiTra.SanPhamMoi[0].SanPham.TenSP : 'Sản phẩm khác' %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                            </div>

                                            <% if (hd.YeuCauDoiTra && (hd.YeuCauDoiTra.TrangThai==='Đã xử lý' ||
                                                hd.YeuCauDoiTra.TrangThai==='Đã duyệt' )) { %>
                                                <% if (hd.YeuCauDoiTra.LoaiYeuCau==='Trả hàng' ) { %>
                                                    <button class="bg-slate-100 text-slate-400 font-bold py-2.5 px-6 rounded-full border border-slate-200 flex items-center cursor-not-allowed hidden md:flex">
                                                        <i class="bi bi-star-fill mr-2 text-slate-300"></i> Đã trả hàng
                                                    </button>
                                                <% } else if (hd.YeuCauDoiTra.LoaiYeuCau==='Đổi hàng' ) { %>
                                                    <button class="bg-slate-100 text-slate-400 font-bold py-2.5 px-6 rounded-full border border-slate-200 flex items-center cursor-not-allowed hidden md:flex">
                                                        <i class="bi bi-arrow-repeat mr-2 text-slate-300"></i> Đã đổi hàng
                                                    </button>
                                                <% } %>
                                            <% } else { %>
                                                <a href="/sanpham/<%= item.SanPham._id %>"
                                                    class="bg-amber-50 hover:bg-amber-100 text-amber-600 font-bold py-2.5 px-6 rounded-full border border-amber-200 transition-colors flex items-center whitespace-nowrap hidden md:flex">
                                                    <i class="bi bi-star-fill mr-2"></i> Xem / Đánh giá
                                                </a>
                                            <% } %>
                                        </div>
                                        <% } %>
                                            <% }) %>
                            </div>

                            <div class="bg-white px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-6 border-t-[1.5px] border-dashed border-slate-200">
                                <div class="flex flex-col items-center md:items-start">
                                    <span class="text-slate-400 font-bold uppercase tracking-wider text-xs mb-1">Tổng cộng</span>
                                    <span class="text-red-500 text-3xl font-black tracking-tight"><%= hd.TongTien.toLocaleString('vi-VN') %> <span class="text-xl underline font-bold">đ</span></span>
                                </div>

                                <% if (hd.TrangThai==='Chờ duyệt') { %>
                                    <div class="bg-amber-50 text-amber-600 font-bold py-3 px-6 rounded-full border border-amber-200 flex items-center cursor-not-allowed">
                                        <i class="bi bi-hourglass-split mr-2"></i> Đang chờ cửa hàng xác nhận
                                    </div>
                                <% } else if (hd.TrangThai==='Từ chối' || hd.TrangThai==='Đã hủy') { %>
                                    <div class="bg-slate-200 text-slate-500 font-bold py-3 px-6 rounded-full flex items-center cursor-not-allowed">
                                        <i class="bi bi-slash-circle mr-2"></i> Đơn hàng đã hủy
                                    </div>
                                <% } else if (hd.HinhThucThanhToan === 'Trả góp' && hd.TraGopInfo && hd.TraGopInfo.TrangThai !== 'Đã tất toán') { %>
                                        <!-- Đơn trả góp ĐANG TRẢ: khóa đổi/trả -->
                                        <div class="bg-blue-50 text-blue-600 font-bold py-3 px-6 rounded-full border border-blue-200 flex items-center cursor-not-allowed"
                                            title="Hoàn thành trả góp mới được Đổi/Trả">
                                            <i class="bi bi-credit-card-2-front mr-2"></i> Đang trả góp (<%= hd.TraGopInfo.SoThangDaTra %>/<%= hd.TraGopInfo.SoThang %> tháng)
                                        </div>
                                        <% } else if (hd.YeuCauDoiTra) { %>
                                            <div class="bg-slate-100 text-slate-500 font-bold py-3 px-6 rounded-full border border-slate-200 flex items-center cursor-not-allowed"
                                                title="Đơn hàng này đã có lịch sử Đổi/Trả">
                                                <i class="bi bi-lock-fill mr-2"></i> Đã xử lý Đổi/Trả
                                            </div>
                                            <% } else if (hd.daDanhGiaSanPham) { %>
                                                <div class="bg-slate-100 text-slate-500 font-bold py-3 px-6 rounded-full border border-slate-200 flex items-center cursor-not-allowed"
                                                    title="Sản phẩm đã được đánh giá, không thể đổi trả">
                                                    <i class="bi bi-lock-fill mr-2"></i> Đã đánh giá (Không thể Đổi/Trả)
                                                </div>
                                                <% } else { %>
                                                    <button type="button"
                                                        onclick="document.getElementById('modalDoiTra<%= hd._id %>').classList.remove('hidden')"
                                                        class="bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-6 rounded-full shadow-md transition-colors flex items-center">
                                                        <i class="bi bi-arrow-left-right mr-2"></i> Yêu cầu Đổi/Trả hàng
                                                    </button>
                                                    <% } %>

                            </div>
                        </div>

                        <% if (hd.TrangThai !=='Chờ duyệt' && hd.TrangThai !=='Từ chối' && hd.TrangThai !=='Đã hủy' && (!hd.YeuCauDoiTra) && (!hd.daDanhGiaSanPham) && !(hd.HinhThucThanhToan === 'Trả góp' && hd.TraGopInfo && hd.TraGopInfo.TrangThai !== 'Đã tất toán')) { %>
                            <div id="modalDoiTra<%= hd._id %>"
                                class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm hidden transition-opacity">
                                <div
                                    class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden m-4 relative animate-[pulse_0.2s_ease-out]">

                                    <button type="button"
                                        onclick="document.getElementById('modalDoiTra<%= hd._id %>').classList.add('hidden')"
                                        class="absolute top-4 right-4 text-slate-400 hover:text-slate-600 transition-colors">
                                        <i class="bi bi-x-circle-fill text-2xl"></i>
                                    </button>

                                    <form action="/yeucau-doitra" method="POST">
                                        <div class="p-6 md:p-8">
                                            <h3 class="text-2xl font-extrabold text-slate-900 mb-6">Yêu cầu Đổi/Trả
                                                <br><span class="text-brand-600 text-lg">Đơn #<%=
                                                        hd._id.toString().slice(-6).toUpperCase() %></span></h3>
                                            <input type="hidden" name="HoaDonId" value="<%= hd._id %>">
                                            <div class="mb-5">
                                                <label class="block text-sm font-bold text-slate-700 mb-2">Loại yêu
                                                    cầu</label>
                                                <select name="LoaiYeuCau" id="loaiYeuCau<%= hd._id %>"
                                                    onchange="toggleSPMoi('<%= hd._id %>')"
                                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 font-medium cursor-pointer">
                                                    <option value="Trả hàng">Trả hàng (Hoàn tiền)</option>
                                                    <option value="Đổi hàng">Đổi hàng (Lấy Tivi khác)</option>
                                                </select>
                                            </div>
                                            <div class="mb-5 hidden" id="chonSPMoi<%= hd._id %>">
                                                <label class="block text-sm font-bold text-slate-700 mb-2">Chọn Sản phẩm
                                                    muốn đổi</label>
                                                <select name="SanPhamMoiId"
                                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 font-medium cursor-pointer">
                                                    <% if(typeof sanpham !=='undefined' ) { %>
                                                        <% sanpham.forEach(sp=> { %>
                                                            <option value="<%= sp._id %>">
                                                                <%= sp.TenSP %> - <%= sp.GiaBan.toLocaleString('vi-VN')
                                                                        %> đ
                                                            </option>
                                                            <% }) %>
                                                                <% } %>
                                                </select>
                                            </div>
                                            <div class="mb-2">
                                                <label class="block text-sm font-bold text-slate-700 mb-2">Lý do chi
                                                    tiết</label>
                                                <textarea name="LyDo" rows="4" required
                                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 font-medium resize-none"
                                                    placeholder="Vui lòng nhập lý do (VD: Tivi bị lỗi màn hình, không lên nguồn...)"></textarea>
                                            </div>
                                        </div>
                                        <div
                                            class="bg-slate-50 px-6 py-5 border-t border-slate-100 flex justify-end gap-3">
                                            <button type="button"
                                                onclick="document.getElementById('modalDoiTra<%= hd._id %>').classList.add('hidden')"
                                                class="px-6 py-2.5 rounded-full font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-100 transition-colors">Hủy
                                                bỏ</button>
                                            <button type="submit"
                                                class="px-6 py-2.5 rounded-full font-bold text-white bg-brand-600 hover:bg-brand-700 shadow-md transition-colors">Gửi
                                                yêu cầu</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <% } %>
                                <% }) %>
                </div>
                <% } else { %>
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-16 text-center">
                        <i class="bi bi-cart-x text-slate-300 text-7xl mb-4 block"></i>
                        <h4 class="text-2xl font-bold text-slate-800 mb-2">Bạn chưa mua gì cả!</h4>
                        <p class="text-slate-500 mb-6">Hãy khám phá các sản phẩm Tivi tuyệt vời tại cửa hàng nhé.</p>
                        <a href="/sanpham"
                            class="inline-flex items-center justify-center bg-brand-600 hover:bg-brand-700 text-white font-bold py-3.5 px-8 rounded-full shadow-lg transition-transform hover:-translate-y-1">
                            Bắt đầu mua sắm ngay
                        </a>
                    </div>
                    <% } %>
        </div>

        <%- include('footer') %>

            <script>
                function toggleSPMoi(id) {
                    const loai = document.getElementById('loaiYeuCau' + id).value;
                    const divSPMoi = document.getElementById('chonSPMoi' + id);
                    if (loai === 'Đổi hàng') {
                        divSPMoi.classList.remove('hidden');
                    } else {
                        divSPMoi.classList.add('hidden');
                    }
                }
            </script>
</body>

</html>