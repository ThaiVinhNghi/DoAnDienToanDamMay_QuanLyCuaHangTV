<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <%- include('navbar') %>

    <div class="container mt-5 mb-5 flex-grow-1">
        <h2 class="fw-bold mb-4 text-primary"><i class="bi bi-clock-history me-2"></i> Lịch Sử Mua Hàng</h2>

        <% if(hoadon && hoadon.length > 0) { %>
            <div class="row g-4">
                <% hoadon.forEach(hd => { %>
                    <div class="col-12">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                            <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-muted fs-5">Mã Đơn: #<%= hd._id.toString().slice(-6).toUpperCase() %></span>
                                <span class="badge bg-success px-3 py-2 fs-6 shadow-sm"><i class="bi bi-check-circle me-1"></i> Đã thanh toán</span>
                            </div>
                            
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    <% hd.ChiTietHoaDon.forEach(item => { %>
                                        <% if (item.SanPham) { %>
                                        <li class="list-group-item p-4 d-flex align-items-center justify-content-between">
                                            <div class="d-flex align-items-center">
                                                <img src="/images/<%= item.SanPham.HinhAnh %>" alt="<%= item.SanPham.TenSP %>" class="img-thumbnail me-4 border-0 bg-light rounded-3" style="width: 100px; height: 100px; object-fit: contain;">
                                                <div>
                                                    <h5 class="fw-bold mb-2 text-dark"><%= item.SanPham.TenSP %></h5>
                                                    <span class="text-danger fw-bold fs-6"><%= item.DonGiaBan ? item.DonGiaBan.toLocaleString('vi-VN') : item.SanPham.GiaBan.toLocaleString('vi-VN') %> đ</span> 
                                                    <span class="text-muted ms-2">x <%= item.SoLuong %></span>
                                                </div>
                                            </div>
                                            
                                            <a href="/sanpham/<%= item.SanPham._id %>" class="btn btn-outline-warning fw-bold rounded-pill px-4 py-2 shadow-sm">
                                                <i class="bi bi-star-fill me-1"></i> Đánh giá ngay
                                            </a>
                                        </li>
                                        <% } %>
                                    <% }) %>
                                </ul>
                            </div>

                            <div class="card-footer bg-light border-top p-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                                <div>
                                    <span class="text-muted fs-5">Tổng tiền:</span>
                                    <span class="text-danger fs-3 fw-bold ms-2"><%= hd.TongTien.toLocaleString('vi-VN') %> đ</span>
                                </div>
                                
                                <button class="btn btn-warning fw-bold rounded-pill px-4 py-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalDoiTra<%= hd._id %>">
                                    <i class="bi bi-arrow-left-right me-1"></i> Yêu cầu Đổi/Trả hàng
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="modal fade" id="modalDoiTra<%= hd._id %>" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content rounded-4 border-0 shadow">
                                <form action="/yeucau-doitra" method="POST">
                                    <div class="modal-header border-bottom-0 pb-0 mt-2">
                                        <h5 class="modal-title fw-bold text-dark">Yêu cầu Đổi/Trả đơn #<%= hd._id.toString().slice(-6).toUpperCase() %></h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4">
                                        <input type="hidden" name="HoaDonId" value="<%= hd._id %>">
                                        
                                        <div class="mb-4">
                                            <label class="form-label fw-bold text-secondary">Loại yêu cầu</label>
                                            <select class="form-select form-select-lg" name="LoaiYeuCau" id="loaiYeuCau<%= hd._id %>" onchange="toggleSPMoi('<%= hd._id %>')">
                                                <option value="Trả hàng">Trả hàng (Hoàn tiền)</option>
                                                <option value="Đổi hàng">Đổi hàng (Lấy Tivi khác)</option>
                                            </select>
                                        </div>
                                        
                                        <div class="mb-4" id="chonSPMoi<%= hd._id %>" style="display: none;">
                                            <label class="form-label fw-bold text-secondary">Chọn Sản phẩm muốn đổi</label>
                                            <select class="form-select form-select-lg" name="SanPhamMoiId">
                                                <% sanpham.forEach(sp => { %>
                                                    <option value="<%= sp._id %>"><%= sp.TenSP %> - <%= sp.GiaBan.toLocaleString('vi-VN') %> đ</option>
                                                <% }) %>
                                            </select>
                                        </div>

                                        <div class="mb-2">
                                            <label class="form-label fw-bold text-secondary">Lý do Đổi/Trả</label>
                                            <textarea class="form-control" name="LyDo" rows="4" required placeholder="Vui lòng cho chúng tôi biết lý do chi tiết..."></textarea>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                                        <button type="button" class="btn btn-light rounded-pill px-4 py-2 fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                                        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">Gửi yêu cầu ngay</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-5 bg-white rounded-4 shadow-sm mt-4 border">
                <i class="bi bi-cart-x text-muted opacity-25" style="font-size: 6rem;"></i>
                <h4 class="text-muted mt-3 fw-bold">Bạn chưa có lịch sử mua hàng nào!</h4>
                <a href="/sanpham" class="btn btn-primary rounded-pill px-5 py-3 mt-4 fw-bold shadow-sm">Bắt đầu mua sắm ngay</a>
            </div>
        <% } %>
    </div>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Script để ẩn/hiện menu chọn Tivi khi khách bấm Đổi Hàng
        function toggleSPMoi(id) {
            const loai = document.getElementById('loaiYeuCau' + id).value;
            const divSPMoi = document.getElementById('chonSPMoi' + id);
            if (loai === 'Đổi hàng') {
                divSPMoi.style.display = 'block';
            } else {
                divSPMoi.style.display = 'none';
            }
        }
    </script>
</body>
</html>