<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('navbar') %>

    <div class="container mt-4 mb-4">
        <div id="bannerCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-indicators mb-4">
                <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active" data-bs-interval="4000">
                    <div class="p-5 text-center d-flex flex-column justify-content-center align-items-center"
                        style="height: 380px; background: linear-gradient(135deg, #0984e3, #74b9ff);">
                        <h1 class="display-4 fw-bold text-white mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.2);">Đón Lễ Lớn - Sale Chạm Đáy 50%</h1>
                        <p class="lead text-white mb-4 opacity-75">Sở hữu ngay siêu phẩm Smart Tivi 4K, OLED với giá chưa từng có.</p>
                        <a href="#khuyen-mai" class="btn btn-gradient-warning btn-lg fw-bold rounded-pill px-5 py-3">
                            <i class="bi bi-lightning-charge-fill"></i> Săn Deal Ngay
                        </a>
                    </div>
                </div>
                <div class="carousel-item" data-bs-interval="4000">
                    <div class="p-5 text-center d-flex flex-column justify-content-center align-items-center"
                        style="height: 380px; background: linear-gradient(135deg, #d63031, #ff7675);">
                        <h1 class="display-4 fw-bold text-white mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.2);">Thế Giới Tivi OLED Đỉnh Cao</h1>
                        <p class="lead text-white mb-4 opacity-75">Mang rạp chiếu phim chuẩn Hollywood về ngay phòng khách nhà bạn.</p>
                        <a href="#tat-ca-san-pham" class="btn btn-light btn-lg fw-bold rounded-pill text-danger px-5 py-3 shadow-sm">
                            <i class="bi bi-stars"></i> Khám Phá Ngay
                        </a>
                    </div>
                </div>
                <div class="carousel-item" data-bs-interval="4000">
                    <div class="p-5 text-center d-flex flex-column justify-content-center align-items-center"
                        style="height: 380px; background: linear-gradient(135deg, #00b894, #55efc4);">
                        <h1 class="display-4 fw-bold text-white mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.2);">Trả Góp 0% Lãi Suất</h1>
                        <p class="lead text-white mb-4 opacity-75">Thủ tục nhanh gọn - Miễn phí lắp đặt tận nhà siêu tốc.</p>
                        <a href="#lien-he" class="btn btn-dark btn-lg fw-bold rounded-pill px-5 py-3 shadow-sm">
                            <i class="bi bi-headset"></i> Liên Hệ Tư Vấn
                        </a>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>

    <div class="container mb-5">
        <div class="filter-wrapper mx-auto">
            <form action="/" method="GET" class="row g-2 align-items-center m-0">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0 ps-4 rounded-start-pill text-primary"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control filter-box ps-2" name="timkiem" placeholder="Nhập tên Tivi cần tìm..." value="<%= query.timkiem || '' %>">
                    </div>
                </div>
                
                <div class="col-md-3">
                    <select name="gia" class="form-select filter-box">
                        <option value="">Mọi mức giá</option>
                        <option value="duoi10" <%=query.gia=='duoi10' ? 'selected' : '' %>>Dưới 10.000.000 đ</option>
                        <option value="10den20" <%=query.gia=='10den20' ? 'selected' : '' %>>10.000.000 - 20.000.000 đ</option>
                        <option value="tren20" <%=query.gia=='tren20' ? 'selected' : '' %>>Trên 20.000.000 đ</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-filter w-100 py-2"><i class="bi bi-funnel-fill me-1"></i> LỌC</button>
                </div>
            </form>
        </div>
    </div>

    <div class="container flex-grow-1 mb-5">

        <% if(spgiamgia.length > 0) { %>
            <div class="d-flex flex-wrap justify-content-between align-items-end mb-4" id="khuyen-mai">
                <div class="d-flex align-items-center gap-3">
                    <h3 class="section-title text-danger mb-0"><i class="bi bi-lightning-charge-fill"></i> Săn Sale Giờ Vàng</h3>
                </div>
                <div class="flash-sale-timer">02:59:59</div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4 mb-5 pb-4 border-bottom">
                <% spgiamgia.forEach(sp=> { %>
                    <div class="col">
                        <div class="product-card h-100 d-flex flex-column position-relative">
                            <span class="badge-sale-tag">-20%</span>
                            
                            <a href="/sanpham/<%= sp._id %>" class="text-decoration-none d-flex flex-column flex-grow-1">
                                <div class="product-img-wrap">
                                    <img src="/images/<%= sp.HinhAnh %>" class="product-img" alt="<%= sp.TenSP %>">
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <span class="badge badge-brand mb-2 align-self-start"><%= sp.HangSanXuat ? sp.HangSanXuat.TenHang : 'N/A' %></span>
                                    <h6 class="product-title" title="<%= sp.TenSP %>"><%= sp.TenSP %></h6>
                                    
                                    <% 
                                        let tbSaoKM = 0; let soDGKM = 0;
                                        if(sp.DanhGia && sp.DanhGia.length > 0) {
                                            soDGKM = sp.DanhGia.length;
                                            let tongSao = sp.DanhGia.reduce((sum, dg) => sum + dg.SoSao, 0);
                                            tbSaoKM = (tongSao / soDGKM).toFixed(1);
                                        }
                                    %>
                                    <div class="mb-1 mt-1 text-start" style="font-size: 13px;">
                                        <span class="text-warning fw-bold"><i class="bi bi-star-fill"></i> <%= tbSaoKM > 0 ? tbSaoKM : 'Chưa có' %></span>
                                        <% if(soDGKM > 0) { %>
                                            <span class="text-muted ms-1">(<%= soDGKM %>)</span>
                                        <% } %>
                                    </div>
                                    
                                    <div class="mt-auto pt-3 border-top border-light">
                                        <div class="price-old mb-1"><%= (sp.GiaBan * 1.2).toLocaleString('vi-VN') %> đ</div>
                                        <div class="price-new"><%= sp.GiaBan.toLocaleString('vi-VN') %> đ</div>
                                    </div>
                                </div>
                            </a>
                            <div class="p-3 pt-0 mt-auto">
                               <a href="/themvaogio/<%= sp._id %>" class="btn btn-buy-sale w-100 py-2">
                                    <i class="bi bi-cart-plus-fill me-1"></i> Bỏ vào giỏ ngay
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <div class="mb-4" id="tat-ca-san-pham">
            <h3 class="section-title"><i class="bi bi-grid-fill text-primary"></i> Khám Phá Sản Phẩm</h3>
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            <% if(sanpham.length > 0) { %>
                <% sanpham.forEach(sp=> { %>
                    <div class="col">
                        <div class="product-card h-100 d-flex flex-column">
                            <a href="/sanpham/<%= sp._id %>" class="text-decoration-none d-flex flex-column flex-grow-1">
                                <div class="product-img-wrap border-bottom border-light">
                                    <img src="/images/<%= sp.HinhAnh %>" class="product-img" alt="<%= sp.TenSP %>">
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <span class="badge badge-brand mb-2 align-self-start"><%= sp.HangSanXuat ? sp.HangSanXuat.TenHang : 'N/A' %></span>
                                    <h6 class="product-title" title="<%= sp.TenSP %>"><%= sp.TenSP %></h6>
                                    
                                    <% 
                                        let tbSao = 0; let soDanhGia = 0;
                                        if(sp.DanhGia && sp.DanhGia.length > 0) {
                                            soDanhGia = sp.DanhGia.length;
                                            let tongSao = sp.DanhGia.reduce((sum, dg) => sum + dg.SoSao, 0);
                                            tbSao = (tongSao / soDanhGia).toFixed(1);
                                        }
                                    %>
                                    <div class="mb-1 mt-1 text-start" style="font-size: 13px;">
                                        <span class="text-warning fw-bold"><i class="bi bi-star-fill"></i> <%= tbSao > 0 ? tbSao : 'Chưa có' %></span>
                                        <% if(soDanhGia > 0) { %>
                                            <span class="text-muted ms-1">(<%= soDanhGia %>)</span>
                                        <% } %>
                                    </div>

                                    <div class="price-new mt-auto pt-3"><%= sp.GiaBan.toLocaleString('vi-VN') %> đ</div>
                                </div>
                            </a>
                            <div class="p-3 pt-0 mt-auto">
                                <a href="/themvaogio/<%= sp._id %>" class="btn btn-buy w-100 py-2">
                                    <i class="bi bi-cart-plus"></i> Chọn Mua
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486754.png" width="120" class="mb-3 opacity-50" alt="Not found">
                    <h5 class="text-secondary fw-bold">Rất tiếc, không có Tivi nào khớp với tìm kiếm của bạn!</h5>
                    <a href="/" class="btn btn-primary mt-3 rounded-pill px-5 py-2 fw-bold">Xóa bộ lọc</a>
                </div>
            <% } %>
        </div>

    </div>

    <div class="container mb-5" id="bangtin">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <h3 class="section-title m-0"><i class="bi bi-newspaper text-primary me-2"></i> Bảng tin Công Nghệ</h3>
            <a href="/tintuc" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
                Xem tất cả <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="row g-4">
            <% if (tintuc && tintuc.length > 0) { %>
                <% tintuc.forEach(t => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="transition: transform 0.3s;">
                            <% let imgSrc = t.HinhAnh.startsWith('http') ? t.HinhAnh : '/images/' + t.HinhAnh; %>
                            <img src="<%= imgSrc %>" class="card-img-top" alt="<%= t.TieuDe %>" style="height: 200px; object-fit: cover;">
                            <div class="card-body p-4 d-flex flex-column">
                                <span class="badge bg-light text-secondary mb-2 align-self-start"><i class="bi bi-calendar3"></i> <%= new Date(t.NgayDang).toLocaleDateString('vi-VN') %></span>
                                <h5 class="card-title fw-bold text-dark mb-3"><%= t.TieuDe %></h5>
                                <p class="card-text text-muted mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= t.TomTat %></p>
                                <a href="/tin/<%= t._id %>" class="mt-auto fw-bold text-primary text-decoration-none">Đọc tiếp <i class="bi bi-chevron-right"></i></a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12"><p class="text-muted text-center py-4">Chưa có bảng tin để hiển thị.</p></div>
            <% } %>
        </div>
    </div>

    <div class="container mb-5 mt-5 bg-white p-4 rounded-4 shadow-sm">
        <div class="row g-4">
            <div class="col-lg-7">
                <h4 class="fw-bold mb-3 text-dark"><i class="bi bi-geo-alt-fill text-danger me-2"></i>Bản Đồ Đường Đi</h4>
                <div class="rounded-4 overflow-hidden border">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d490.6158388358315!2d105.45986987650394!3d10.347745325088344!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x310a73994fe3fd7f%3A0x5e333044c1f1b7c0!2zUXXDoW4gVHLDoCBT4buvYSBUaMO5eSBUcmFuZw!5e0!3m2!1svi!2s!4v1774806226593!5m2!1svi!2s" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
            <div class="col-lg-5">
                <h4 class="fw-bold mb-3 text-dark"><i class="bi bi-facebook text-primary me-2"></i>Cộng Đồng TVN</h4>
                <div class="rounded-4 overflow-hidden border d-flex align-items-center justify-content-center bg-light">
                    <iframe src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fnghi.vinh.58726%2F&tabs=timeline&width=400&height=350&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true&appId" 
                        width="100%" height="350" style="border:none; overflow:hidden;" scrolling="no" frameborder="0" allowfullscreen="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"></iframe>
                </div>
            </div>
        </div>
    </div>

    <div class="container mb-5 mt-4" id="lien-he">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4" style="background-color: #ffffff;">
                    <div class="card-body p-4 p-lg-5">
                        <h4 class="fw-bold mb-4 text-primary"><i class="bi bi-shop me-2"></i>Cửa Hàng Tivi TVN</h4>
                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-geo-alt-fill text-danger fs-5 me-3"></i>
                            <p class="mb-0 text-secondary"><strong>Địa chỉ:</strong> 54/98 Đường Trần Quang Khải, Phường Mỹ Thới, TP. Long Xuyên</p>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-telephone-fill text-success fs-5 me-3"></i>
                            <p class="mb-0 text-secondary"><strong>Hotline:</strong> <a href="tel:0931082845" class="text-decoration-none fw-bold text-success fs-5">0931.082.845</a></p>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-envelope-fill text-warning fs-5 me-3"></i>
                            <p class="mb-0 text-secondary"><strong>Email:</strong> <a href="mailto:hotro@tivin.com" class="text-decoration-none text-dark fw-bold">hotro@tivin.com</a></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 rounded-4" style="background: linear-gradient(135deg, #0d6efd, #0052cc);">
                    <div class="card-body p-4 p-lg-5 text-center d-flex flex-column justify-content-center text-white">
                        <i class="bi bi-headset display-4 mb-3 opacity-75"></i>
                        <h4 class="fw-bold mb-3">Hỗ trợ khách hàng 24/7</h4>
                        <p class="mb-4 opacity-75">Bạn cần tư vấn chọn mua Tivi hoặc hỗ trợ bảo hành trả góp? Đừng ngần ngại gọi ngay cho chúng tôi!</p>
                        <a href="tel:0123456789" class="btn btn-light btn-lg fw-bold text-primary rounded-pill px-5 py-3 shadow-sm mx-auto" style="width: fit-content;">
                            <i class="bi bi-telephone-outbound-fill me-2"></i> GỌI NGAY CHO TVN
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('footer') %>

    <a href="https://zalo.me/0931082845" target="_blank" class="zalo-btn" title="Chat Zalo ngay!">
        <svg xmlns="http://www.w3.org/2000/svg" fill="white" viewBox="0 0 16 16">
            <path d="M8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6-.097 1.016-.417 2.13-.771 2.966-.079.186.074.394.273.362 2.256-.37 3.597-.938 4.18-1.234A9.06 9.06 0 0 0 8 15z" />
        </svg>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    
    <script>
        document.addEventListener('keydown', function(event) {
            if (event.ctrlKey && event.shiftKey && (event.key === 'b' || event.key === 'B')) {
                event.preventDefault(); 
                window.location.href = '/admin/dangnhap'; 
            }
        });
    </script>
</body>
</html>