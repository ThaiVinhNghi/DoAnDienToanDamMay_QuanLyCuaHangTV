<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#eff6ff', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' } } } }
        }
    </script>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

        <div class="container mx-auto px-4 mt-8 mb-16 flex-grow">
            <h3 class="text-2xl font-extrabold text-slate-900 mb-6"><i
                    class="bi bi-cart-check text-brand-600 mr-2"></i>Giỏ hàng của bạn</h3>

            <div class="flex flex-col lg:flex-row gap-8">
                <div class="lg:w-2/3">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden mb-6">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-slate-50 text-slate-500 text-sm uppercase font-bold">
                                    <tr>
                                        <th class="px-6 py-4 text-center">Sản phẩm</th>
                                        <th class="px-6 py-4">Tên Tivi</th>
                                        <th class="px-6 py-4">Đơn giá</th>
                                        <th class="px-6 py-4 text-center">SL</th>
                                        <th class="px-6 py-4">Thành tiền</th>
                                        <th class="px-6 py-4 text-center">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    <% if (giohang.length> 0) { %>
                                        <% giohang.forEach(item=> { %>
                                            <tr class="hover:bg-slate-50 transition-colors">
                                                <td class="px-6 py-4 text-center">
                                                    <% let imgSrc=item.HinhAnh.startsWith('http') ? item.HinhAnh
                                                        : '/images/' + item.HinhAnh; %>
                                                        <img src="<%= imgSrc %>" alt="<%= item.TenSP %>"
                                                            class="w-16 h-16 object-contain mx-auto bg-white rounded-xl border border-slate-100 p-1">
                                                </td>
                                                <td class="px-6 py-4 font-bold text-slate-800">
                                                    <%= item.TenSP %>
                                                </td>
                                                <td class="px-6 py-4 font-semibold text-slate-600">
                                                    <%= item.GiaBan.toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td class="px-6 py-4 text-center font-bold text-slate-800">
                                                    <%= item.SoLuong %>
                                                </td>
                                                <td class="px-6 py-4 font-bold text-danger-600 text-red-500">
                                                    <%= item.ThanhTien.toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td class="px-6 py-4 text-center">
                                                    <a href="/xoagiohang/<%= item.SanPhamId %>"
                                                        class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-red-500 hover:bg-red-100 hover:text-red-700 transition-colors"
                                                        title="Xóa khỏi giỏ">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="px-6 py-12 text-center text-slate-400">
                                                            <i class="bi bi-cart-x text-5xl mb-3 block"></i>
                                                            <p class="font-semibold text-lg">Giỏ hàng của bạn đang
                                                                trống.</p>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <a href="/sanpham"
                        class="inline-flex items-center font-bold text-brand-600 hover:text-brand-700 transition-colors bg-white border border-brand-200 px-6 py-3 rounded-full shadow-sm hover:shadow-md">
                        <i class="bi bi-arrow-left mr-2"></i> Tiếp tục mua sắm
                    </a>
                </div>

                <div class="lg:w-1/3">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 md:p-8 sticky top-24">
                        <h5 class="text-xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Thông tin Đơn
                            hàng</h5>

                        <div class="flex justify-between mb-4">
                            <span class="text-slate-500 font-medium">Tổng phụ:</span>
                            <strong class="text-slate-800">
                                <%= tongTien.toLocaleString('vi-VN') %> đ
                            </strong>
                        </div>
                        <div class="flex justify-between mb-6 pb-6 border-b border-slate-100">
                            <span class="text-slate-500 font-medium">Phí giao hàng:</span>
                            <strong class="text-emerald-500 bg-emerald-50 px-2 py-1 rounded-md text-sm">Miễn phí</strong>
                        </div>
                        <div class="flex justify-between items-center mb-8">
                            <span class="text-lg font-bold text-slate-900">Tổng cộng:</span>
                            <strong class="text-2xl font-extrabold text-red-500">
                                <%= tongTien.toLocaleString('vi-VN') %> đ
                            </strong>
                        </div>

                        <% if (!khachhang) { %>
                            <div
                                class="bg-amber-50 text-amber-700 p-4 rounded-2xl text-sm font-bold mb-4 text-center border border-amber-100">
                                Bạn cần đăng nhập để tiến hành đặt hàng.
                            </div>
                            <a href="/dangnhap"
                                class="block w-full bg-amber-500 hover:bg-amber-600 text-white font-bold text-center py-4 rounded-xl shadow-lg shadow-amber-500/30 transition-transform hover:-translate-y-1">
                                <i class="bi bi-box-arrow-in-right mr-2"></i> Đăng nhập ngay
                            </a>
                        <% } else if (giohang.length===0) { %>
                            <button type="button"
                                class="w-full bg-slate-200 text-slate-500 font-bold py-4 rounded-xl cursor-not-allowed" disabled>
                                Chưa có sản phẩm
                            </button>
                        <% } else { %>
                            <form action="/thanhtoan" method="POST" onsubmit="return validateTuoiTraGop(event)">
                                <div
                                    class="bg-emerald-50 border border-emerald-100 text-emerald-700 p-4 rounded-2xl text-sm mb-6 flex items-start">
                                    <i class="bi bi-geo-alt-fill mt-0.5 mr-2 text-lg"></i>
                                    <div>
                                        <span class="block font-semibold mb-1">Giao đến địa chỉ:</span>
                                        <strong>
                                            <%= khachhang.DiaChi %>
                                        </strong>
                                    </div>
                                </div>

                                <h6 class="font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Hình thức thanh toán</h6>

                                <label class="flex items-center p-4 border border-slate-200 rounded-2xl mb-3 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50">
                                    <input type="radio" name="HinhThucThanhToan" value="Trả hết" checked
                                        class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                        onchange="document.getElementById('khuVucTraGop').style.display='none'; document.getElementById('khuVucChuyenKhoan').style.display='none'; document.getElementById('CCCD').required=false; document.getElementById('NgaySinh').required=false;">
                                    <span class="ml-3 font-bold text-slate-800"><i class="bi bi-cash-coin text-emerald-500 mr-2 text-lg"></i>Thanh toán khi nhận hàng (COD)</span>
                                </label>

                                <label class="flex items-center p-4 border border-slate-200 rounded-2xl mb-3 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50">
                                    <input type="radio" name="HinhThucThanhToan" value="Chuyển khoản"
                                        class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                        onchange="document.getElementById('khuVucTraGop').style.display='none'; document.getElementById('khuVucChuyenKhoan').style.display='block'; document.getElementById('CCCD').required=false; document.getElementById('NgaySinh').required=false;">
                                    <span class="ml-3 font-bold text-slate-800"><i class="bi bi-qr-code-scan text-blue-500 mr-2 text-lg"></i>Thanh toán Chuyển khoản (Quét QR)</span>
                                </label>

                                <label class="flex items-center p-4 border border-slate-200 rounded-2xl mb-2 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50 <%= typeof isNoXau !== 'undefined' && isNoXau ? 'opacity-50' : '' %>">
                                    <input type="radio" name="HinhThucThanhToan" value="Trả góp"
                                        class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                        onchange="document.getElementById('khuVucTraGop').style.display='block'; document.getElementById('khuVucChuyenKhoan').style.display='none'; document.getElementById('CCCD').required=true; document.getElementById('NgaySinh').required=true;"
                                        <%=typeof isNoXau !=='undefined' && isNoXau ? 'disabled' : '' %>>
                                    <span class="ml-3 font-bold text-slate-800"><i class="bi bi-credit-card text-brand-500 mr-2 text-lg"></i>Mua trả góp qua thẻ/CCCD</span>
                                </label>

                                <% if(typeof isNoXau !=='undefined' && isNoXau) { %>
                                    <div class="text-red-500 mt-2 text-sm font-bold bg-red-50 p-2 rounded-lg flex items-center mb-4">
                                        <i class="bi bi-exclamation-triangle-fill mr-2"></i> Tính năng trả góp bị khóa do Nợ Xấu!
                                    </div>
                                <% } %>

                                <div id="khuVucChuyenKhoan" class="mt-4 p-5 bg-white border border-brand-100 rounded-2xl shadow-inner mb-6 hidden text-center">
                                    <p class="font-bold text-slate-700 mb-4">Quét mã QR dưới đây để thanh toán:</p>
                                    <img src="/images/qr_chuyenkhoan.jpg" alt="Mã QR Chuyển khoản" class="mx-auto border border-slate-200 shadow-sm rounded-xl max-w-[220px] mb-4">
                                    <p class="text-sm text-slate-500">Nội dung chuyển khoản (bắt buộc):</p>
                                    <div class="bg-blue-50 text-blue-700 font-extrabold text-lg py-2 px-4 rounded-lg inline-block my-2 border border-blue-100">
                                        MUA TIVI <%= khachhang.SoDienThoai %>
                                    </div>
                                    <p class="text-xs italic text-red-500 mt-2"><i class="bi bi-info-circle mr-1"></i>Đơn hàng sẽ được nhân viên duyệt sau khi cửa hàng nhận được tiền.</p>
                                </div>

                                <div class="mt-4 p-5 bg-white border border-brand-100 rounded-2xl shadow-inner mb-6 hidden" id="khuVucTraGop">
                                    
                                    <div class="mb-4">
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Số CCCD (12 số):</label>
                                        <input type="text" id="CCCD" name="CCCD" pattern="[0-9]{12}" title="Vui lòng nhập đúng 12 số Căn cước công dân" placeholder="Ví dụ: 079012345678"
                                            class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 font-medium">
                                    </div>

                                    <div class="mb-4 border-b border-slate-100 pb-4">
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Ngày tháng năm sinh:</label>
                                        <input type="date" id="NgaySinh" name="NgaySinh"
                                            class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 font-medium">
                                        <p class="text-red-500 text-xs mt-2 italic font-semibold">* Khách hàng phải từ đủ 18 tuổi.</p>
                                    </div>

                                    <label class="block text-sm font-bold text-slate-700 mb-2">Chọn kỳ hạn trả góp:</label>
                                    <select name="SoThangTraGop"
                                        class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 mb-4 font-medium cursor-pointer">
                                        <option value="3">Góp 3 tháng</option>
                                        <option value="6" selected>Góp 6 tháng</option>
                                        <option value="9">Góp 9 tháng</option>
                                        <option value="12">Góp 12 tháng</option>
                                    </select>

                                    <div class="bg-amber-100 text-amber-800 font-bold px-3 py-2 rounded-lg text-sm inline-flex items-center">
                                        <i class="bi bi-percent mr-1"></i> Lãi suất: 1% / tháng
                                    </div>
                                    <p class="text-slate-500 text-xs mt-3 italic"><i class="bi bi-info-circle mr-1"></i>Nhân viên sẽ gọi điện hướng dẫn thủ tục sau khi đặt hàng.</p>
                                </div>

                                <button type="submit"
                                    class="w-full bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white font-extrabold text-lg py-4 rounded-xl shadow-xl shadow-emerald-500/30 transition-transform hover:-translate-y-1 mt-4 flex justify-center items-center">
                                    <i class="bi bi-check-circle-fill mr-2"></i> ĐẶT HÀNG NGAY
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>

        <script>
            function validateTuoiTraGop(event) {
                // Kiểm tra xem khách có chọn hình thức Trả góp không
                const hinhThuc = document.querySelector('input[name="HinhThucThanhToan"]:checked').value;
                
                if (hinhThuc === 'Trả góp') {
                    const dobInput = document.getElementById('NgaySinh').value;
                    if (!dobInput) return true; // Trình duyệt sẽ tự báo lỗi vì đã có thuộc tính 'required'

                    const dob = new Date(dobInput);
                    const today = new Date();
                    
                    // Tính tuổi
                    let age = today.getFullYear() - dob.getFullYear();
                    const monthDiff = today.getMonth() - dob.getMonth();
                    
                    // Chỉnh sửa nếu chưa tới sinh nhật trong năm nay
                    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
                        age--;
                    }

                    if (age < 18) {
                        alert("Rất tiếc! Bạn phải từ đủ 18 tuổi trở lên mới được tham gia mua trả góp.");
                        event.preventDefault(); // Chặn việc submit form
                        return false;
                    }
                }
                return true;
            }
        </script>
</body>

</html>