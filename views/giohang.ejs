<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light d-flex flex-column min-vh-100">

    <%- include('navbar') %>

    <div class="container mt-5 mb-5 flex-grow-1">
        <h3 class="mb-4 fw-bold text-primary"><i class="bi bi-cart-check"></i> Giỏ hàng của bạn</h3>

        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="15%" class="text-center">Sản phẩm</th>
                                    <th>Tên Tivi</th>
                                    <th>Đơn giá</th>
                                    <th width="10%" class="text-center">SL</th>
                                    <th>Thành tiền</th>
                                    <th width="10%" class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (giohang.length > 0) { %>
                                    <% giohang.forEach(item => { %>
                                        <tr>
                                            <td class="text-center py-3">
                                                <img src="/images/<%= item.HinhAnh %>" alt="<%= item.TenSP %>"
                                                    width="60" class="img-thumbnail border-0 bg-light">
                                            </td>
                                            <td class="fw-bold"><%= item.TenSP %></td>
                                            <td class="text-danger"><%= item.GiaBan.toLocaleString('vi-VN') %> đ</td>
                                            <td class="text-center fw-bold"><%= item.SoLuong %></td>
                                            <td class="text-danger fw-bold"><%= item.ThanhTien.toLocaleString('vi-VN') %> đ</td>
                                            <td class="text-center">
                                                <a href="/xoagiohang/<%= item.SanPhamId %>"
                                                    class="btn btn-sm btn-outline-danger" title="Xóa khỏi giỏ">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="bi bi-cart-x fs-1 d-block mb-3"></i> 
                                            Giỏ hàng của bạn đang trống.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <a href="/" class="btn btn-outline-primary rounded-pill fw-bold">
                    <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
                </a>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card border-0 shadow-sm rounded-4 bg-white">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin Đơn hàng</h5>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng phụ:</span>
                            <strong class="text-dark"><%= tongTien.toLocaleString('vi-VN') %> đ</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-4 pb-3 border-bottom">
                            <span class="text-muted">Phí giao hàng:</span>
                            <strong class="text-success">Miễn phí</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Tổng cộng:</span>
                            <strong class="fs-4 text-danger"><%= tongTien.toLocaleString('vi-VN') %> đ</strong>
                        </div>

                        <% if (!khachhang) { %>
                            <div class="alert alert-warning small text-center fw-bold">
                                Bạn cần đăng nhập để tiến hành đặt hàng.
                            </div>
                            <a href="/dangnhap" class="btn btn-warning w-100 rounded-pill fw-bold py-2 shadow-sm">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập ngay
                            </a>
                        <% } else if (giohang.length === 0) { %>
                            <button type="button" class="btn btn-secondary w-100 rounded-pill fw-bold py-2" disabled>
                                Chưa có sản phẩm
                            </button>
                        <% } else { %>
                            <form action="/thanhtoan" method="POST">
                                <div class="alert alert-success small text-center mb-3">
                                    <i class="bi bi-geo-alt-fill"></i> Giao đến: 
                                    <strong><%= khachhang.DiaChi %></strong>
                                </div>

                                <h6 class="fw-bold mt-4 mb-3 border-bottom pb-2">Hình thức thanh toán</h6>

                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="radio" name="HinhThucThanhToan"
                                        id="trahet" value="Trả hết" checked
                                        onchange="document.getElementById('khuVucTraGop').style.display='none';">
                                    <label class="form-check-label text-dark fw-bold" for="trahet">
                                        <i class="bi bi-cash-coin text-success me-1"></i> Thanh toán khi nhận hàng
                                    </label>
                                </div>

                                <div class="form-check mb-4 border rounded p-3 bg-light">
                                    <input class="form-check-input ms-0 me-2" type="radio"
                                        name="HinhThucThanhToan" id="tragop" value="Trả góp"
                                        onchange="document.getElementById('khuVucTraGop').style.display='block';"
                                        <%= typeof isNoXau !== 'undefined' && isNoXau ? 'disabled' : '' %>> <label class="form-check-label fw-bold <%= typeof isNoXau !== 'undefined' && isNoXau ? 'text-muted' : 'text-dark' %>" for="tragop">
                                        <i class="bi bi-credit-card text-primary me-1"></i> Mua trả góp qua thẻ / CCCD
                                    </label>

                                    <% if(typeof isNoXau !== 'undefined' && isNoXau) { %>
                                        <div class="text-danger mt-2 small fw-bold">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Tính năng trả góp bị khóa do tài khoản có Nợ Xấu!
                                        </div>
                                    <% } %>

                                    <div id="khuVucTraGop" class="mt-3 ms-4 p-3 bg-white border rounded shadow-sm" style="display: none;">
                                        <label class="form-label small fw-bold text-secondary mb-2">Chọn kỳ hạn trả góp:</label>
                                        <select name="SoThangTraGop" class="form-select border-primary mb-3">
                                            <option value="3">Góp 3 tháng</option>
                                            <option value="6" selected>Góp 6 tháng</option>
                                            <option value="9">Góp 9 tháng</option>
                                            <option value="12">Góp 12 tháng</option>
                                        </select>
                                        <div class="d-flex align-items-center">
                                            <span class="badge bg-warning text-dark px-3 py-2 fs-6">
                                                <i class="bi bi-percent"></i> Lãi suất: 1% / tháng
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-0 mt-3 ms-4">Nhân viên sẽ gọi điện hướng dẫn thủ tục sau khi đặt hàng.</p>
                                </div>

                                <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-3 fs-5 shadow-sm btn-dat-hang">
                                    <i class="bi bi-check-circle"></i> ĐẶT HÀNG NGAY
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        /* Thêm hiệu ứng cho nút đặt hàng */
        .btn-dat-hang { transition: all 0.3s ease; }
        .btn-dat-hang:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(25, 135, 84, 0.3) !important; }
    </style>
</body>
</html>