<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#eff6ff', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' } } } }
        }
    </script>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

        <div class="container mx-auto px-4 mt-8 mb-16 flex-grow">
            <h3 class="text-2xl font-extrabold text-slate-900 mb-6"><i
                    class="bi bi-cart-check text-brand-600 mr-2"></i>Giỏ hàng của bạn</h3>

            <div class="flex flex-col lg:flex-row gap-8">
                <div class="lg:w-2/3">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden mb-6">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-slate-50 text-slate-500 text-sm uppercase font-bold">
                                    <tr>
                                        <th class="px-6 py-4 text-center">Sản phẩm</th>
                                        <th class="px-6 py-4">Tên Tivi</th>
                                        <th class="px-6 py-4">Đơn giá</th>
                                        <th class="px-6 py-4 text-center">SL</th>
                                        <th class="px-6 py-4">Thành tiền</th>
                                        <th class="px-6 py-4 text-center">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    <% if (giohang.length> 0) { %>
                                        <% giohang.forEach(item=> { %>
                                            <tr class="hover:bg-slate-50 transition-colors">
                                                <td class="px-6 py-4 text-center">
                                                    <% let imgSrc=item.HinhAnh.startsWith('http') ? item.HinhAnh
                                                        : '/images/' + item.HinhAnh; %>
                                                        <img src="<%= imgSrc %>" alt="<%= item.TenSP %>"
                                                            class="w-16 h-16 object-contain mx-auto bg-white rounded-xl border border-slate-100 p-1">
                                                </td>
                                                <td class="px-6 py-4 font-bold text-slate-800">
                                                    <%= item.TenSP %>
                                                </td>
                                                <td class="px-6 py-4 font-semibold text-slate-600">
                                                    <%= item.GiaBan.toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td class="px-6 py-4 text-center font-bold text-slate-800">
                                                    <%= item.SoLuong %>
                                                </td>
                                                <td class="px-6 py-4 font-bold text-danger-600 text-red-500">
                                                    <%= item.ThanhTien.toLocaleString('vi-VN') %> đ
                                                </td>
                                                <td class="px-6 py-4 text-center">
                                                    <a href="/xoagiohang/<%= item.SanPhamId %>"
                                                        class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-red-500 hover:bg-red-100 hover:text-red-700 transition-colors"
                                                        title="Xóa khỏi giỏ">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="px-6 py-12 text-center text-slate-400">
                                                            <i class="bi bi-cart-x text-5xl mb-3 block"></i>
                                                            <p class="font-semibold text-lg">Giỏ hàng của bạn đang
                                                                trống.</p>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <a href="/sanpham"
                        class="inline-flex items-center font-bold text-brand-600 hover:text-brand-700 transition-colors bg-white border border-brand-200 px-6 py-3 rounded-full shadow-sm hover:shadow-md">
                        <i class="bi bi-arrow-left mr-2"></i> Tiếp tục mua sắm
                    </a>
                </div>

                <div class="lg:w-1/3">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 md:p-8 sticky top-24">
                        <h5 class="text-xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Thông tin Đơn
                            hàng</h5>

                        <div class="flex justify-between mb-4">
                            <span class="text-slate-500 font-medium">Tổng phụ:</span>
                            <strong class="text-slate-800">
                                <%= tongTien.toLocaleString('vi-VN') %> đ
                            </strong>
                        </div>
                        <div class="flex justify-between mb-6 pb-6 border-b border-slate-100">
                            <span class="text-slate-500 font-medium">Phí giao hàng:</span>
                            <strong class="text-emerald-500 bg-emerald-50 px-2 py-1 rounded-md text-sm">Miễn
                                phí</strong>
                        </div>
                        <div class="flex justify-between items-center mb-8">
                            <span class="text-lg font-bold text-slate-900">Tổng cộng:</span>
                            <strong class="text-2xl font-extrabold text-red-500">
                                <%= tongTien.toLocaleString('vi-VN') %> đ
                            </strong>
                        </div>

                        <% if (!khachhang) { %>
                            <div
                                class="bg-amber-50 text-amber-700 p-4 rounded-2xl text-sm font-bold mb-4 text-center border border-amber-100">
                                Bạn cần đăng nhập để tiến hành đặt hàng.
                            </div>
                            <a href="/dangnhap"
                                class="block w-full bg-amber-500 hover:bg-amber-600 text-white font-bold text-center py-4 rounded-xl shadow-lg shadow-amber-500/30 transition-transform hover:-translate-y-1">
                                <i class="bi bi-box-arrow-in-right mr-2"></i> Đăng nhập ngay
                            </a>
                            <% } else if (giohang.length===0) { %>
                                <button type="button"
                                    class="w-full bg-slate-200 text-slate-500 font-bold py-4 rounded-xl cursor-not-allowed"
                                    disabled>
                                    Chưa có sản phẩm
                                </button>
                                <% } else { %>
                                    <form action="/thanhtoan" method="POST" id="form-thanhtoan">

                                        <div class="mb-5 p-4 bg-emerald-50 border border-emerald-200 rounded-2xl">
                                            <div class="flex items-center mb-3">
                                                <i class="bi bi-geo-alt-fill text-emerald-600 text-lg mr-2"></i>
                                                <span class="font-bold text-slate-800 text-sm">Địa chỉ giao hàng</span>
                                            </div>

                                            <!-- ====== KHU VỰC CHỌN ĐỊA CHỈ CŨ (chỉ hiện khi có lịch sử) ====== -->
                                            <% if (typeof diaChiCu !== 'undefined' && diaChiCu.length > 0) { %>
                                            <div class="mb-4">
                                                <p class="text-xs font-bold text-emerald-700 mb-2 flex items-center gap-1">
                                                    <i class="bi bi-clock-history"></i> Địa chỉ đã dùng trước đây:
                                                </p>

                                                <!-- Radio: Chọn địa chỉ mới -->
                                                <label id="label-dia-chi-moi"
                                                    class="dia-chi-option flex items-start gap-3 p-3 mb-2 bg-white border-2 border-emerald-500 rounded-xl cursor-pointer transition-all">
                                                    <input type="radio" name="_chonDiaChi" value="__moi__" checked
                                                        class="mt-0.5 w-4 h-4 text-emerald-600 focus:ring-emerald-500 border-slate-300 shrink-0">
                                                    <span class="text-sm font-bold text-emerald-700">
                                                        <i class="bi bi-plus-circle mr-1"></i>Nhập địa chỉ mới
                                                    </span>
                                                </label>

                                                <!-- Radio: Các địa chỉ cũ -->
                                                <% diaChiCu.forEach(function(dc, idx) { %>
                                                <label id="label-dia-chi-cu-<%= idx %>"
                                                    class="dia-chi-option flex items-start gap-3 p-3 mb-2 bg-white border-2 border-slate-200 rounded-xl cursor-pointer hover:border-emerald-400 transition-all">
                                                    <input type="radio" name="_chonDiaChi" value="<%= dc %>"
                                                        class="mt-0.5 w-4 h-4 text-emerald-600 focus:ring-emerald-500 border-slate-300 shrink-0">
                                                    <span class="text-sm font-semibold text-slate-700 leading-snug">
                                                        <i class="bi bi-geo-alt text-emerald-500 mr-1"></i><%= dc %>
                                                    </span>
                                                </label>
                                                <% }); %>
                                            </div>
                                            <% } %>
                                            <!-- ====== KẾT THÚC KHU VỰC ĐỊA CHỈ CŨ ====== -->

                                            <!-- Wrapper form điền địa chỉ mới (ẩn/hiện tùy chọn) -->
                                            <div id="khuVucDiaChiMoi">

                                            <!-- Dropdown Tỉnh/Thành phố -->
                                            <div class="mb-3">
                                                <label class="block text-xs font-semibold text-slate-600 mb-1">Tỉnh /
                                                    Thành phố <span class="text-red-500">*</span></label>
                                                <div class="relative">
                                                    <select id="ddl-tinh" name="sel_tinh"
                                                        class="w-full appearance-none bg-white border border-slate-200 text-slate-800 rounded-xl px-4 py-2.5 pr-8 outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-sm font-medium cursor-pointer transition-colors">
                                                        <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                                    </select>
                                                    <i
                                                        class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-xs"></i>
                                                </div>
                                            </div>

                                            <!-- Dropdown Quận/Huyện -->
                                            <div class="mb-3">
                                                <label class="block text-xs font-semibold text-slate-600 mb-1">Quận /
                                                    Huyện <span class="text-red-500">*</span></label>
                                                <div class="relative">
                                                    <select id="ddl-quan" name="sel_quan" disabled
                                                        class="w-full appearance-none bg-white border border-slate-200 text-slate-800 rounded-xl px-4 py-2.5 pr-8 outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-sm font-medium cursor-pointer transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                                        <option value="">-- Chọn Quận/Huyện --</option>
                                                    </select>
                                                    <i
                                                        class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-xs"></i>
                                                </div>
                                            </div>

                                            <!-- Dropdown Phường/Xã -->
                                            <div class="mb-3">
                                                <label class="block text-xs font-semibold text-slate-600 mb-1">Phường /
                                                    Xã <span class="text-red-500">*</span></label>
                                                <div class="relative">
                                                    <select id="ddl-phuong" name="sel_phuong" disabled
                                                        class="w-full appearance-none bg-white border border-slate-200 text-slate-800 rounded-xl px-4 py-2.5 pr-8 outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-sm font-medium cursor-pointer transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                                        <option value="">-- Chọn Phường/Xã --</option>
                                                    </select>
                                                    <i
                                                        class="bi bi-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-xs"></i>
                                                </div>
                                            </div>

                                            <!-- Số nhà / Tên đường -->
                                            <div class="mb-3">
                                                <label class="block text-xs font-semibold text-slate-600 mb-1">Số nhà,
                                                    Tên đường <span class="text-red-500">*</span></label>
                                                <input type="text" id="inp-sonha" name="inp_sonha"
                                                    placeholder="Ví dụ: 123 Đường Lê Lợi"
                                                    class="w-full bg-white border border-slate-200 text-slate-800 rounded-xl px-4 py-2.5 outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 text-sm font-medium placeholder-slate-400 transition-colors">
                                            </div>

                                            <!-- Preview địa chỉ đầy đủ -->
                                            <div id="dia-chi-preview"
                                                class="hidden mt-2 p-3 bg-white border border-emerald-300 rounded-xl">
                                                <p class="text-xs text-slate-500 mb-1 font-semibold"><i
                                                        class="bi bi-check-circle-fill text-emerald-500 mr-1"></i>Địa
                                                    chỉ giao hàng:</p>
                                                <p id="dia-chi-preview-text" class="text-sm font-bold text-slate-800">
                                                </p>
                                            </div>

                                            </div><!-- /khuVucDiaChiMoi -->

                                            <!-- Hidden input chứa địa chỉ đầy đủ đã ghép -->
                                            <input type="hidden" id="DiaChiGiaoHang" name="DiaChiGiaoHang">
                                        </div>


                                        <h6 class="font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Hình
                                            thức thanh toán</h6>

                                        <label
                                            class="flex items-center p-4 border border-slate-200 rounded-2xl mb-3 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50">
                                            <input type="radio" name="HinhThucThanhToan" value="Trả hết" checked
                                                class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                                onchange="document.getElementById('khuVucTraGop').style.display='none'; document.getElementById('khuVucChuyenKhoan').style.display='none'; document.getElementById('CCCD').required=false; document.getElementById('NgaySinh').required=false;">
                                            <span class="ml-3 font-bold text-slate-800"><i
                                                    class="bi bi-cash-coin text-emerald-500 mr-2 text-lg"></i>Thanh toán
                                                khi nhận hàng (COD)</span>
                                        </label>

                                        <label
                                            class="flex items-center p-4 border border-slate-200 rounded-2xl mb-3 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50">
                                            <input type="radio" name="HinhThucThanhToan" value="Chuyển khoản"
                                                class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                                onchange="document.getElementById('khuVucTraGop').style.display='none'; document.getElementById('khuVucChuyenKhoan').style.display='block'; document.getElementById('CCCD').required=false; document.getElementById('NgaySinh').required=false;">
                                            <span class="ml-3 font-bold text-slate-800"><i
                                                    class="bi bi-qr-code-scan text-blue-500 mr-2 text-lg"></i>Thanh toán
                                                Chuyển khoản (Quét QR)</span>
                                        </label>

                                        <label
                                            class="flex items-center p-4 border border-slate-200 rounded-2xl mb-2 cursor-pointer hover:border-brand-500 transition-colors bg-slate-50 <%= typeof isNoXau !== 'undefined' && isNoXau ? 'opacity-50' : '' %>">
                                            <input type="radio" name="HinhThucThanhToan" value="Trả góp"
                                                class="w-5 h-5 text-brand-600 focus:ring-brand-500 border-slate-300"
                                                onchange="document.getElementById('khuVucTraGop').style.display='block'; document.getElementById('khuVucChuyenKhoan').style.display='none'; document.getElementById('CCCD').required=true; document.getElementById('NgaySinh').required=true;"
                                                <%=typeof isNoXau !=='undefined' && isNoXau ? 'disabled' : '' %>>
                                            <span class="ml-3 font-bold text-slate-800"><i
                                                    class="bi bi-credit-card text-brand-500 mr-2 text-lg"></i>Mua trả
                                                góp qua thẻ/CCCD</span>
                                        </label>

                                        <% if(typeof isNoXau !=='undefined' && isNoXau) { %>
                                            <div
                                                class="text-red-500 mt-2 text-sm font-bold bg-red-50 p-2 rounded-lg flex items-center mb-4">
                                                <i class="bi bi-exclamation-triangle-fill mr-2"></i> Tính năng trả góp
                                                bị khóa do Nợ Xấu!
                                            </div>
                                            <% } %>

                                                <div id="khuVucChuyenKhoan"
                                                    class="mt-4 p-5 bg-white border border-brand-100 rounded-2xl shadow-inner mb-6 hidden text-center">
                                                    <p class="font-bold text-slate-700 mb-4">Quét mã QR dưới đây để
                                                        thanh toán:</p>
                                                    <img src="/images/qr_chuyenkhoan.jpg" alt="Mã QR Chuyển khoản"
                                                        class="mx-auto border border-slate-200 shadow-sm rounded-xl max-w-[220px] mb-4">
                                                    <p class="text-sm text-slate-500">Nội dung chuyển khoản (bắt buộc):
                                                    </p>
                                                    <div
                                                        class="bg-blue-50 text-blue-700 font-extrabold text-lg py-2 px-4 rounded-lg inline-block my-2 border border-blue-100">
                                                        MUA TIVI <%= khachhang.SoDienThoai %>
                                                    </div>
                                                    <p class="text-xs italic text-red-500 mt-2"><i
                                                            class="bi bi-info-circle mr-1"></i>Đơn hàng sẽ được nhân
                                                        viên duyệt sau khi cửa hàng nhận được tiền.</p>
                                                </div>

                                                <div class="mt-4 p-5 bg-white border border-brand-100 rounded-2xl shadow-inner mb-6 hidden"
                                                    id="khuVucTraGop">

                                                    <div class="mb-4">
                                                        <label class="block text-sm font-bold text-slate-700 mb-2">Số
                                                            CCCD (12 số):</label>
                                                        <input type="text" id="CCCD" name="CCCD" pattern="[0-9]{12}"
                                                            title="Vui lòng nhập đúng 12 số Căn cước công dân"
                                                            placeholder="Ví dụ: 079012345678"
                                                            class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 font-medium">
                                                    </div>

                                                    <div class="mb-4 border-b border-slate-100 pb-4">
                                                        <label class="block text-sm font-bold text-slate-700 mb-2">Ngày
                                                            tháng năm sinh:</label>
                                                        <input type="date" id="NgaySinh" name="NgaySinh"
                                                            class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 font-medium">
                                                        <p class="text-red-500 text-xs mt-2 italic font-semibold">*
                                                            Khách hàng phải từ đủ 18 tuổi.</p>
                                                    </div>

                                                    <label class="block text-sm font-bold text-slate-700 mb-2">Chọn kỳ
                                                        hạn trả góp:</label>
                                                    <select name="SoThangTraGop"
                                                        class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 mb-4 font-medium cursor-pointer">
                                                        <option value="3">Góp 3 tháng</option>
                                                        <option value="6" selected>Góp 6 tháng</option>
                                                        <option value="9">Góp 9 tháng</option>
                                                        <option value="12">Góp 12 tháng</option>
                                                    </select>

                                                    <div
                                                        class="bg-amber-100 text-amber-800 font-bold px-3 py-2 rounded-lg text-sm inline-flex items-center">
                                                        <i class="bi bi-percent mr-1"></i> Lãi suất: 1% / tháng
                                                    </div>
                                                    <p class="text-slate-500 text-xs mt-3 italic"><i
                                                            class="bi bi-info-circle mr-1"></i>Nhân viên sẽ gọi điện
                                                        hướng dẫn thủ tục sau khi đặt hàng.</p>
                                                </div>

                                                <button type="submit"
                                                    class="w-full bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white font-extrabold text-lg py-4 rounded-xl shadow-xl shadow-emerald-500/30 transition-transform hover:-translate-y-1 mt-4 flex justify-center items-center">
                                                    <i class="bi bi-check-circle-fill mr-2"></i> ĐẶT HÀNG NGAY
                                                </button>
                                    </form>
                                    <% } %>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>

            <script>
                // ============================================================
                // VALIDATE TUỔI TRẢ GÓP
                // ============================================================
                function validateTuoiTraGop(event) {
                    const hinhThuc = document.querySelector('input[name="HinhThucThanhToan"]:checked').value;

                    if (hinhThuc === 'Trả góp') {
                        const dobInput = document.getElementById('NgaySinh').value;
                        if (!dobInput) return true;

                        const dob = new Date(dobInput);
                        const today = new Date();
                        let age = today.getFullYear() - dob.getFullYear();
                        const monthDiff = today.getMonth() - dob.getMonth();
                        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) age--;

                        if (age < 18) {
                            alert("Rất tiếc! Bạn phải từ đủ 18 tuổi trở lên mới được tham gia mua trả góp.");
                            event.preventDefault();
                            return false;
                        }
                    }
                    return true;
                }

                // ============================================================
                // CHỌN ĐỊA CHỈ CŨ HAY ĐỊA CHỈ MỚI
                // ============================================================
                const hiddenDiaChi = document.getElementById('DiaChiGiaoHang');
                const khuVucDiaChiMoi = document.getElementById('khuVucDiaChiMoi');
                const preview = document.getElementById('dia-chi-preview');
                const previewText = document.getElementById('dia-chi-preview-text');

                // Hàm cập nhật trạng thái border khi chọn radio địa chỉ
                function capNhatBorderDiaChi() {
                    document.querySelectorAll('.dia-chi-option').forEach(lbl => {
                        const radio = lbl.querySelector('input[type="radio"]');
                        if (radio && radio.checked) {
                            lbl.classList.remove('border-slate-200');
                            lbl.classList.add('border-emerald-500');
                        } else {
                            lbl.classList.remove('border-emerald-500');
                            lbl.classList.add('border-slate-200');
                        }
                    });
                }

                // Xử lý khi chọn radio địa chỉ
                document.querySelectorAll('input[name="_chonDiaChi"]').forEach(radio => {
                    radio.addEventListener('change', function() {
                        capNhatBorderDiaChi();
                        if (this.value === '__moi__') {
                            // Chọn nhập mới: hiện form dropdown, xóa giá trị hidden
                            if (khuVucDiaChiMoi) {
                                khuVucDiaChiMoi.style.display = 'block';
                                khuVucDiaChiMoi.style.animation = 'fadeIn 0.2s ease';
                            }
                            hiddenDiaChi.value = '';
                            if (preview) preview.classList.add('hidden');
                        } else {
                            // Chọn địa chỉ cũ: ẩn form dropdown, set giá trị hidden ngay lập tức
                            if (khuVucDiaChiMoi) khuVucDiaChiMoi.style.display = 'none';
                            hiddenDiaChi.value = this.value;
                            // Hiện preview địa chỉ cũ đã chọn
                            if (preview && previewText) {
                                previewText.textContent = this.value;
                                preview.classList.remove('hidden');
                            }
                        }
                    });
                });

                // Khởi tạo: Nếu mặc định là "Nhập mới" thì hiện form, nếu đã là địa chỉ cũ thì ẩn
                (function initDiaChiMode() {
                    const selected = document.querySelector('input[name="_chonDiaChi"]:checked');
                    if (selected && selected.value !== '__moi__') {
                        if (khuVucDiaChiMoi) khuVucDiaChiMoi.style.display = 'none';
                        hiddenDiaChi.value = selected.value;
                    }
                    capNhatBorderDiaChi();
                })();

                // ============================================================
                // API ĐỊA GIỚI HÀNH CHÍNH VIỆT NAM (provinces.open-api.vn)
                // ============================================================
                const API_BASE = 'https://provinces.open-api.vn/api';

                const ddlTinh = document.getElementById('ddl-tinh');
                const ddlQuan = document.getElementById('ddl-quan');
                const ddlPhuong = document.getElementById('ddl-phuong');
                const inpSoNha = document.getElementById('inp-sonha');

                // ---- Hàm ghép địa chỉ đầy đủ ----
                function capNhatDiaChi() {
                    const tinh = ddlTinh.options[ddlTinh.selectedIndex]?.text || '';
                    const quan = ddlQuan.options[ddlQuan.selectedIndex]?.text || '';
                    const phuong = ddlPhuong.options[ddlPhuong.selectedIndex]?.text || '';
                    const soNha = inpSoNha.value.trim();

                    if (tinh && tinh !== '-- Chọn Tỉnh/Thành phố --' &&
                        quan && quan !== '-- Chọn Quận/Huyện --' &&
                        phuong && phuong !== '-- Chọn Phường/Xã --' && soNha) {
                        const diaChi = `${soNha}, ${phuong}, ${quan}, ${tinh}`;
                        hiddenDiaChi.value = diaChi;
                        previewText.textContent = diaChi;
                        preview.classList.remove('hidden');
                    } else {
                        hiddenDiaChi.value = '';
                        preview.classList.add('hidden');
                    }
                }

                // ---- Bước 1: Load danh sách Tỉnh/Thành phố khi trang mở ----
                async function loadTinh() {
                    if (!ddlTinh) return; // Không có phần tử thì thôi
                    try {
                        const res = await fetch(`${API_BASE}/?depth=1`);
                        const data = await res.json();
                        data.sort((a, b) => a.name.localeCompare(b.name, 'vi'));
                        ddlTinh.innerHTML = '<option value="">-- Chọn Tỉnh/Thành phố --</option>';
                        data.forEach(tinh => {
                            const opt = document.createElement('option');
                            opt.value = tinh.code;
                            opt.textContent = tinh.name;
                            ddlTinh.appendChild(opt);
                        });
                    } catch (err) {
                        console.error('Lỗi load Tỉnh:', err);
                    }
                }

                // ---- Bước 2: Khi chọn Tỉnh → Load Quận/Huyện ----
                if (ddlTinh) {
                    ddlTinh.addEventListener('change', async function () {
                        const code = this.value;
                        ddlQuan.innerHTML = '<option value="">-- Chọn Quận/Huyện --</option>';
                        ddlPhuong.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
                        ddlQuan.disabled = true;
                        ddlPhuong.disabled = true;
                        hiddenDiaChi.value = '';
                        preview.classList.add('hidden');

                        if (!code) return;

                        try {
                            const res = await fetch(`${API_BASE}/p/${code}?depth=2`);
                            const data = await res.json();
                            const districts = data.districts || [];
                            districts.sort((a, b) => a.name.localeCompare(b.name, 'vi'));
                            districts.forEach(quan => {
                                const opt = document.createElement('option');
                                opt.value = quan.code;
                                opt.textContent = quan.name;
                                ddlQuan.appendChild(opt);
                            });
                            ddlQuan.disabled = false;
                        } catch (err) {
                            console.error('Lỗi load Quận:', err);
                        }
                    });
                }

                // ---- Bước 3: Khi chọn Quận → Load Phường/Xã ----
                if (ddlQuan) {
                    ddlQuan.addEventListener('change', async function () {
                        const code = this.value;
                        ddlPhuong.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
                        ddlPhuong.disabled = true;
                        hiddenDiaChi.value = '';
                        preview.classList.add('hidden');

                        if (!code) return;

                        try {
                            const res = await fetch(`${API_BASE}/d/${code}?depth=2`);
                            const data = await res.json();
                            const wards = data.wards || [];
                            wards.sort((a, b) => a.name.localeCompare(b.name, 'vi'));
                            wards.forEach(phuong => {
                                const opt = document.createElement('option');
                                opt.value = phuong.code;
                                opt.textContent = phuong.name;
                                ddlPhuong.appendChild(opt);
                            });
                            ddlPhuong.disabled = false;
                        } catch (err) {
                            console.error('Lỗi load Phường:', err);
                        }
                    });
                }

                // ---- Bước 4: Khi chọn Phường hoặc nhập số nhà → cập nhật preview ----
                if (ddlPhuong) ddlPhuong.addEventListener('change', capNhatDiaChi);
                if (inpSoNha) inpSoNha.addEventListener('input', capNhatDiaChi);

                // ---- Bước 5: Validate trước khi submit form ----
                const form = document.getElementById('form-thanhtoan');
                if (form) {
                    form.addEventListener('submit', function (event) {
                        if (!hiddenDiaChi.value || hiddenDiaChi.value.trim() === '') {
                            const dangChonMoi = document.querySelector('input[name="_chonDiaChi"]:checked')?.value === '__moi__'
                                               || !document.querySelector('input[name="_chonDiaChi"]');
                            if (dangChonMoi) {
                                alert('Vui lòng chọn đầy đủ Tỉnh/Thành phố, Quận/Huyện, Phường/Xã và nhập Số nhà/Đường!');
                            } else {
                                alert('Vui lòng chọn hoặc nhập địa chỉ giao hàng!');
                            }
                            event.preventDefault();
                            return;
                        }
                        validateTuoiTraGop(event);
                    });
                }

                // ---- Khởi động: Load Tỉnh ngay khi trang load ----
                loadTinh();

                // CSS animation fadeIn cho khu vực địa chỉ mới
                const styleEl = document.createElement('style');
                styleEl.textContent = `@keyframes fadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }`;
                document.head.appendChild(styleEl);
            </script>

</body>

</html>