<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#fff0f0', 100: '#fecaca', 200: '#fca5a5', 500: '#dc2626', 600: '#b91c1c', 700: '#991b1b', 800: '#7f1d1d' } } } } }
    </script>
</head>

<body class="min-h-screen bg-slate-50 flex flex-col font-sans">

    <%- include('navbar') %>

        <div class="flex-grow flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden flex max-w-4xl w-full">

                <div class="hidden md:block md:w-1/2 relative bg-brand-600">
                    <img src="https://images.unsplash.com/photo-1614064641913-6b1e6ce40b43?auto=format&fit=crop&w=800&q=80"
                        class="absolute inset-0 w-full h-full object-cover opacity-60" alt="Bảo mật">
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-brand-900/80 to-transparent flex flex-col justify-end p-10 text-white">
                        <h3 class="text-3xl font-bold mb-2">Đừng lo lắng!</h3>
                        <p class="text-brand-100">Hãy nhập thông tin để chúng tôi giúp bạn khôi phục lại quyền truy cập
                            vào tài khoản.</p>
                    </div>
                </div>

                <div class="w-full md:w-1/2 p-8 sm:p-12">
                    <div class="text-center mb-8">
                        <div
                            class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-50 text-amber-500 mb-4 shadow-sm">
                            <i class="bi bi-shield-lock-fill text-3xl"></i>
                        </div>
                        <h2 class="text-2xl font-extrabold text-slate-900">Quên Mật Khẩu?</h2>
                        <p class="text-sm text-slate-500 mt-1">Xác minh danh tính của bạn</p>
                    </div>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg flex items-center">
                            <i class="bi bi-exclamation-circle-fill text-red-500 mr-3 text-lg"></i>
                            <p class="text-sm text-red-700 font-semibold">
                                <%= error %>
                            </p>
                        </div>
                        <% } %>

                            <form action="/quenmatkhau" method="POST" class="space-y-5">
                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Tên đăng nhập</label>
                                    <div class="relative">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-person text-slate-400"></i></div>
                                        <input type="text" name="TenDangNhap" required autofocus
                                            class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                            placeholder="Nhập tên tài khoản...">
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Số điện thoại đăng
                                        ký</label>
                                    <div class="relative">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-telephone text-slate-400"></i></div>
                                        <input type="text" name="SoDienThoai" required
                                            class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                            placeholder="Nhập số điện thoại...">
                                    </div>
                                </div>

                                <button type="submit"
                                    class="w-full bg-brand-600 hover:bg-brand-700 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-brand-500/30 transition-all hover:-translate-y-0.5 mt-4">
                                    TIẾP TỤC
                                </button>
                            </form>

                            <p class="mt-8 text-center text-sm text-slate-600">
                                Nhớ ra mật khẩu rồi? <a href="/dangnhap"
                                    class="font-bold text-brand-600 hover:text-brand-700 transition-colors">Đăng nhập
                                    ngay</a>
                            </p>
                </div>
            </div>
        </div>

        <%- include('footer') %>
</body>

</html>