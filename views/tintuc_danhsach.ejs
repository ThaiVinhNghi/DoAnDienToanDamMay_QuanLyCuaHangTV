<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#fff0f0', 100: '#fecaca', 200: '#fca5a5', 500: '#dc2626', 600: '#b91c1c', 700: '#991b1b', 800: '#7f1d1d' } }
                }
            }
        }
    </script>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

        <div class="relative bg-slate-900 py-20 mb-12">
            <div class="absolute inset-0 overflow-hidden">
                <img src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=1920&q=80"
                    class="w-full h-full object-cover opacity-30" alt="News Banner">
            </div>
            <div class="relative container mx-auto px-4 text-center z-10">
                <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Tin Tức & Công Nghệ</h1>
                <p class="text-lg text-slate-300 max-w-2xl mx-auto">Cập nhật xu hướng, đánh giá chuyên sâu và mẹo hay sử
                    dụng Tivi mỗi ngày.</p>
            </div>
        </div>

        <div class="container mx-auto px-4 flex-grow mb-16">
            <div class="flex justify-between items-center mb-8 border-b border-slate-200 pb-4">
                <h3 class="text-2xl font-extrabold text-slate-900"><i class="bi bi-grid-fill text-brand-500 mr-2"></i>
                    Tất Cả Bài Viết</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% if (tintuc && tintuc.length> 0) { %>
                    <% tintuc.forEach(t=> { %>
                        <div
                            class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
                            <% let imgSrc=t.HinhAnh.startsWith('http') ? t.HinhAnh : '/images/' + t.HinhAnh; %>
                                <a href="/tin/<%= t._id %>" class="block h-56 overflow-hidden">
                                    <img src="<%= imgSrc %>"
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                        alt="<%= t.TieuDe %>">
                                </a>
                                <div class="p-6 flex flex-col flex-grow">
                                    <div
                                        class="flex items-center text-sm text-slate-500 mb-3 font-medium bg-slate-50 w-fit px-3 py-1 rounded-lg border border-slate-100">
                                        <i class="bi bi-calendar3 mr-2 text-brand-500"></i>
                                        <%= new Date(t.NgayDang).toLocaleDateString('vi-VN') %>
                                    </div>
                                    <a href="/tin/<%= t._id %>" class="block">
                                        <h5
                                            class="text-xl font-bold text-slate-900 mb-3 line-clamp-2 group-hover:text-brand-600 transition-colors">
                                            <%= t.TieuDe %>
                                        </h5>
                                    </a>
                                    <p class="text-slate-600 line-clamp-3 mb-6">
                                        <%= t.TomTat %>
                                    </p>

                                    <a href="/tin/<%= t._id %>"
                                        class="mt-auto font-bold text-brand-600 group-hover:text-brand-700 border-t border-slate-100 pt-4 flex items-center transition-colors">
                                        Đọc bài viết <i
                                            class="bi bi-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                                    </a>
                                </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div
                                    class="col-span-full bg-white rounded-3xl shadow-sm border border-slate-100 p-12 text-center">
                                    <i class="bi bi-inboxes text-slate-300 text-6xl mb-4 block"></i>
                                    <h4 class="text-xl font-bold text-slate-700 mb-2">Chưa có bài viết nào!</h4>
                                    <p class="text-slate-500">Hệ thống đang cập nhật các tin tức mới nhất, vui lòng quay
                                        lại sau.</p>
                                </div>
                                <% } %>
            </div>
        </div>

        <%- include('footer') %>
</body>

</html>