<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <%- include('navbar') %>

    <div class="container mt-5 mb-5 flex-grow-1">
        <h2 class="fw-bold mb-4 border-bottom pb-3 text-primary"><i class="bi bi-newspaper me-2"></i> Tất cả Bảng tin Công nghệ</h2>
        
        <div class="row g-4">
            <% if (tintuc && tintuc.length > 0) { %>
                <% tintuc.forEach(t => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="transition: transform 0.3s;">
                            <% let imgSrc = t.HinhAnh.startsWith('http') ? t.HinhAnh : '/images/' + t.HinhAnh; %>
                            <img src="<%= imgSrc %>" class="card-img-top" alt="<%= t.TieuDe %>" style="height: 220px; object-fit: cover;">
                            <div class="card-body p-4 d-flex flex-column">
                                <span class="badge bg-light text-secondary mb-3 align-self-start"><i class="bi bi-calendar3"></i> <%= new Date(t.NgayDang).toLocaleDateString('vi-VN') %></span>
                                <h5 class="card-title fw-bold text-dark mb-3"><%= t.TieuDe %></h5>
                                <p class="card-text text-muted mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= t.TomTat %></p>
                                <a href="/tin/<%= t._id %>" class="mt-auto fw-bold text-primary text-decoration-none border-top pt-3">Đọc tiếp <i class="bi bi-arrow-right ms-1"></i></a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="bi bi-inboxes text-muted opacity-50" style="font-size: 4rem;"></i>
                    <p class="text-muted mt-3 fw-bold">Chưa có bài viết nào.</p>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>