<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#fff0f0', 100: '#fecaca', 200: '#fca5a5', 500: '#dc2626', 600: '#b91c1c', 700: '#991b1b', 800: '#7f1d1d' } } } }
        }
    </script>
    <style>
        .input-field {
            @apply w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all;
        }
        .card { @apply bg-white rounded-3xl shadow-sm border border-slate-100 p-6 md:p-8; }
        .section-title { @apply text-base font-bold text-slate-800 border-b border-slate-100 pb-3 mb-5 flex items-center gap-2; }
    </style>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

    <div class="container mx-auto px-4 mt-8 mb-16 flex-grow max-w-4xl">

        <!-- Tiêu đề trang -->
        <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-xl bg-brand-600 flex items-center justify-center shadow-lg shadow-brand-500/30">
                <i class="bi bi-person-fill text-white text-lg"></i>
            </div>
            <div>
                <h1 class="text-2xl font-extrabold text-slate-900">Thông tin cá nhân</h1>
                <p class="text-sm text-slate-500 mt-0.5">Xem và cập nhật thông tin tài khoản của bạn</p>
            </div>
        </div>

        <!-- Alert thông báo -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-700 px-5 py-4 rounded-2xl flex items-center gap-3 font-semibold text-sm">
                <i class="bi bi-check-circle-fill text-emerald-500 text-lg"></i>
                <%= success %>
            </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-5 py-4 rounded-2xl flex items-center gap-3 font-semibold text-sm">
                <i class="bi bi-exclamation-triangle-fill text-red-500 text-lg"></i>
                <%= error %>
            </div>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- CỘT TRÁI: Avatar + thông tin tóm tắt -->
            <div class="lg:col-span-1">
                <div class="card text-center sticky top-24">
                    <!-- Avatar viết tắt -->
                    <div class="w-24 h-24 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center mx-auto mb-4 shadow-xl shadow-brand-500/30">
                        <span class="text-3xl font-extrabold text-white">
                            <%= khachhang.HoVaTen ? khachhang.HoVaTen.trim().charAt(0).toUpperCase() : '?' %>
                        </span>
                    </div>
                    <h2 class="text-xl font-extrabold text-slate-900 mb-1"><%= khachhang.HoVaTen %></h2>
                    <p class="text-sm text-slate-500 font-medium mb-4">@<%= khachhang.TenDangNhap %></p>

                    <div class="space-y-2.5 text-left">
                        <div class="flex items-center gap-3 bg-slate-50 rounded-xl px-4 py-2.5">
                            <i class="bi bi-telephone-fill text-brand-500"></i>
                            <span class="text-sm font-semibold text-slate-700"><%= khachhang.SoDienThoai || 'Chưa cập nhật' %></span>
                        </div>
                        <div class="flex items-center gap-3 bg-slate-50 rounded-xl px-4 py-2.5">
                            <i class="bi bi-envelope-fill text-brand-500"></i>
                            <span class="text-sm font-semibold text-slate-700 break-all"><%= khachhang.Email || 'Chưa cập nhật' %></span>
                        </div>
                        <div class="flex items-center gap-3 bg-slate-50 rounded-xl px-4 py-2.5">
                            <i class="bi bi-geo-alt-fill text-brand-500"></i>
                            <span class="text-sm font-semibold text-slate-700"><%= khachhang.DiaChi || 'Chưa cập nhật' %></span>
                        </div>
                    </div>

                    <div class="border-t border-slate-100 mt-5 pt-5">
                        <a href="/lichsu" class="flex items-center justify-center gap-2 w-full bg-brand-50 hover:bg-brand-100 text-brand-700 font-bold py-2.5 rounded-xl transition-colors text-sm">
                            <i class="bi bi-receipt"></i> Đơn hàng của tôi
                        </a>
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI: Form chỉnh sửa -->
            <div class="lg:col-span-2 space-y-6">

                <!-- Form thông tin cơ bản -->
                <div class="card">
                    <p class="section-title">
                        <i class="bi bi-pencil-fill text-brand-500"></i>
                        Chỉnh sửa thông tin
                    </p>
                    <form action="/thongtin" method="POST">
                        <input type="hidden" name="_action" value="capnhat">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Họ và tên <span class="text-red-500">*</span></label>
                                <input type="text" name="HoVaTen" value="<%= khachhang.HoVaTen %>" required
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                    placeholder="Nguyễn Văn A">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Tên đăng nhập</label>
                                <input type="text" value="<%= khachhang.TenDangNhap %>" disabled
                                    class="w-full bg-slate-100 border border-slate-200 text-slate-400 rounded-xl px-4 py-3 font-medium cursor-not-allowed"
                                    title="Tên đăng nhập không thể thay đổi">
                                <p class="text-xs text-slate-400 mt-1 italic"><i class="bi bi-lock-fill mr-1"></i>Không thể thay đổi</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Số điện thoại <span class="text-red-500">*</span></label>
                                <input type="text" name="SoDienThoai" value="<%= khachhang.SoDienThoai %>" required
                                    pattern="[0-9]{9,11}" title="Số điện thoại gồm 9-11 chữ số"
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                    placeholder="0901234567">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Email</label>
                                <input type="email" name="Email" value="<%= khachhang.Email || '' %>"
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                    placeholder="example@gmail.com">
                                <p class="text-xs text-emerald-600 mt-1 italic"><i class="bi bi-envelope-check mr-1"></i>Dùng để nhận biên lai đặt hàng</p>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Địa chỉ thường trú <span class="text-red-500">*</span></label>
                            <input type="text" name="DiaChi" value="<%= khachhang.DiaChi %>" required
                                class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                placeholder="123 Đường Lê Lợi, Phường 1, Quận 1, TP.HCM">
                            <p class="text-xs text-slate-400 mt-1 italic"><i class="bi bi-info-circle mr-1"></i>Địa chỉ mặc định — bạn vẫn có thể chọn địa chỉ khác khi đặt hàng</p>
                        </div>

                        <button type="submit"
                            class="w-full bg-gradient-to-r from-brand-500 to-brand-700 hover:from-brand-600 hover:to-brand-800 text-white font-extrabold py-3.5 rounded-xl shadow-lg shadow-brand-500/30 transition-transform hover:-translate-y-0.5 flex justify-center items-center gap-2">
                            <i class="bi bi-check-circle-fill"></i> Lưu thay đổi
                        </button>
                    </form>
                </div>

                <!-- Form đổi mật khẩu -->
                <div class="card">
                    <p class="section-title">
                        <i class="bi bi-shield-lock-fill text-amber-500"></i>
                        Đổi mật khẩu
                    </p>
                    <form action="/thongtin" method="POST">
                        <input type="hidden" name="_action" value="doimatkhau">

                        <div class="mb-4">
                            <label class="block text-sm font-semibold text-slate-600 mb-1.5">Mật khẩu hiện tại <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="password" name="MatKhauCu" required id="mk-cu"
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 pr-12 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                    placeholder="••••••••">
                                <button type="button" onclick="togglePass('mk-cu', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Mật khẩu mới <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <input type="password" name="MatKhauMoi" required id="mk-moi" minlength="6"
                                        class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 pr-12 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                        placeholder="Ít nhất 6 ký tự">
                                    <button type="button" onclick="togglePass('mk-moi', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-600 mb-1.5">Xác nhận mật khẩu mới <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <input type="password" name="XacNhanMatKhau" required id="mk-xn"
                                        class="w-full bg-slate-50 border border-slate-200 text-slate-800 rounded-xl px-4 py-3 pr-12 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-100 font-medium transition-all"
                                        placeholder="Nhập lại mật khẩu mới">
                                    <button type="button" onclick="togglePass('mk-xn', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white font-extrabold py-3.5 rounded-xl shadow-lg shadow-amber-500/30 transition-transform hover:-translate-y-0.5 flex justify-center items-center gap-2">
                            <i class="bi bi-shield-check-fill"></i> Đổi mật khẩu
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <%- include('footer') %>

    <script>
        function togglePass(id, btn) {
            const inp = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                inp.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>

</body>

</html>
