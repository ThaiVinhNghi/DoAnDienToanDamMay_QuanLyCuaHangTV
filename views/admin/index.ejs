<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        /* Hiệu ứng Box Bảng điều khiển */
        .stat-card {
            border-radius: 20px !important;
            border: none !important;
            color: white;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 15px 25px rgba(0,0,0,0.15) !important; }
        .stat-icon {
            position: absolute;
            right: -15px;
            bottom: -25px;
            font-size: 8rem;
            opacity: 0.15;
            transform: rotate(-15deg);
            transition: all 0.3s ease;
        }
        .stat-card:hover .stat-icon { transform: rotate(0deg) scale(1.1); opacity: 0.25; }
        
        /* 4 Màu Gradient Siêu Đẹp */
        .bg-gradient-blue { background: linear-gradient(135deg, #3699ff, #0054cc); }
        .bg-gradient-green { background: linear-gradient(135deg, #1bc5bd, #0a8f88); }
        .bg-gradient-orange { background: linear-gradient(135deg, #ffa800, #c88400); }
        .bg-gradient-red { background: linear-gradient(135deg, #f64e60, #b22736); }
    </style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid p-0">
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bolder text-dark mb-1">Bảng Điều Khiển</h3>
                        <p class="text-muted mb-0">Hệ thống quản lý Cửa hàng Tivi TVN đang hoạt động tốt.</p>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-white text-dark border px-4 py-2 fs-6 shadow-sm rounded-pill">
                            <i class="bi bi-calendar-check text-primary me-2"></i> Hôm nay: <%= new Date().toLocaleDateString('vi-VN') %>
                        </span>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-md-3">
                        <div class="card stat-card bg-gradient-blue h-100 p-4 shadow-sm">
                            <div class="position-relative z-1">
                                <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase letter-spacing">Tổng Tivi</p>
                                <h2 class="display-5 fw-bolder mb-0"><%= soSanPham || 0 %></h2>
                            </div>
                            <i class="bi bi-tv-fill stat-icon"></i>
                        </div>
                    </div>
                    
                    <div class="col-md-3">
                        <div class="card stat-card bg-gradient-green h-100 p-4 shadow-sm">
                            <div class="position-relative z-1">
                                <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase letter-spacing">Đơn Hàng Mới</p>
                                <h2 class="display-5 fw-bolder mb-0"><%= soHoaDon || 0 %></h2>
                            </div>
                            <i class="bi bi-receipt-cutoff stat-icon"></i>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card stat-card bg-gradient-orange h-100 p-4 shadow-sm">
                            <div class="position-relative z-1 text-white">
                                <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase letter-spacing">Khách Hàng</p>
                                <h2 class="display-5 fw-bolder mb-0"><%= soKhachHang || 0 %></h2>
                            </div>
                            <i class="bi bi-people-fill stat-icon text-white"></i>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card stat-card bg-gradient-red h-100 p-4 shadow-sm">
                            <div class="position-relative z-1">
                                <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase letter-spacing">Doanh Thu</p>
                                <h2 class="display-6 fw-bolder mb-0"><%= (tongDoanhThu || 0).toLocaleString('vi-VN') %> đ</h2>
                            </div>
                            <i class="bi bi-piggy-bank-fill stat-icon"></i>
                        </div>
                    </div>
                </div>
                
                <div class="card p-4 rounded-4 shadow-sm border-0 bg-white">
                    <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Hoạt động bán hàng gần đây</h5>
                    <div class="text-center py-5">
                        <img src="https://cdn-icons-png.flaticon.com/512/9660/9660305.png" width="120" class="opacity-25 mb-4">
                        <h6 class="text-muted fw-bold">Hệ thống đang tích lũy dữ liệu để vẽ biểu đồ...</h6>
                        <p class="small text-muted">Biểu đồ sẽ xuất hiện khi có nhiều giao dịch hơn.</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>