<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        .stat-card {
            border-radius: 20px !important;
            border: none !important;
            color: white;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.15) !important;
        }

        .stat-icon {
            position: absolute;
            right: -15px;
            bottom: -25px;
            font-size: 8rem;
            opacity: 0.15;
            transform: rotate(-15deg);
            transition: all 0.3s ease;
        }

        .stat-card:hover .stat-icon {
            transform: rotate(0deg) scale(1.1);
            opacity: 0.25;
        }

        .bg-gradient-blue {
            background: linear-gradient(135deg, #3699ff, #0054cc);
        }

        .bg-gradient-green {
            background: linear-gradient(135deg, #1bc5bd, #0a8f88);
        }

        .bg-gradient-orange {
            background: linear-gradient(135deg, #ffa800, #c88400);
        }

        .bg-gradient-red {
            background: linear-gradient(135deg, #f64e60, #b22736);
        }

        /* Chỉnh style cho list */
        .dashboard-list .list-group-item {
            border-left: none;
            border-right: none;
            border-top: none;
            padding: 1rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .dashboard-list .list-group-item:last-child {
            border-bottom: none;
        }
    </style>
</head>

<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

            <div class="flex-grow-1 p-4 overflow-auto bg-light">
                <div class="container-fluid p-0">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h3 class="fw-bolder text-dark mb-1">Bảng Điều Khiển</h3>
                            <p class="text-muted mb-0">Hệ thống quản lý Cửa hàng Tivi TVN đang hoạt động tốt.</p>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-white text-dark border px-4 py-2 fs-6 shadow-sm rounded-pill">
                                <i class="bi bi-calendar-check text-primary me-2"></i> Hôm nay: <%= new
                                    Date().toLocaleDateString('vi-VN') %>
                            </span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-3">
                            <div class="card stat-card bg-gradient-blue h-100 p-4 shadow-sm">
                                <div class="position-relative z-1">
                                    <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase">Tổng Tivi</p>
                                    <h2 class="display-5 fw-bolder mb-0">
                                        <%= soSanPham || 0 %>
                                    </h2>
                                </div>
                                <i class="bi bi-tv-fill stat-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card bg-gradient-green h-100 p-4 shadow-sm">
                                <div class="position-relative z-1">
                                    <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase">Đơn Chờ Duyệt</p>
                                    <h2 class="display-5 fw-bolder mb-0">
                                        <%= soHoaDon || 0 %>
                                    </h2>
                                </div>
                                <i class="bi bi-receipt-cutoff stat-icon"></i>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card bg-gradient-orange h-100 p-4 shadow-sm">
                                <div class="position-relative z-1 text-white">
                                    <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase">Khách Hàng</p>
                                    <h2 class="display-5 fw-bolder mb-0">
                                        <%= soKhachHang || 0 %>
                                    </h2>
                                </div>
                                <i class="bi bi-people-fill stat-icon text-white"></i>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card bg-gradient-red h-100 p-4 shadow-sm">
                                <div class="position-relative z-1">
                                    <p class="fs-6 fw-bold mb-1 opacity-75 text-uppercase">Doanh Thu</p>
                                    <h2 class="display-6 fw-bolder mb-0">
                                        <%= (tongDoanhThu || 0).toLocaleString('vi-VN') %> đ
                                    </h2>
                                </div>
                                <i class="bi bi-piggy-bank-fill stat-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="card p-4 rounded-4 shadow-sm border-0 bg-white h-100">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold text-dark mb-0"><i
                                            class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Sản phẩm sắp
                                        hết hàng</h5>
                                    <a href="/admin/sanpham" class="btn btn-sm btn-light">Xem kho</a>
                                </div>
                                <ul class="list-group dashboard-list">
                                    <% if(spHetHang.length> 0) { %>
                                        <% spHetHang.forEach(sp=> { %>
                                            <li class="list-group-item px-0">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-light rounded p-2 me-3"><img
                                                            src="<%= sp.HinhAnh.startsWith('http') ? sp.HinhAnh : '/images/' + sp.HinhAnh %>"
                                                            width="40" height="40" style="object-fit: contain;"></div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold text-dark text-truncate"
                                                            style="max-width: 200px;">
                                                            <%= sp.TenSP %>
                                                        </h6>
                                                        <small class="text-muted">Giá: <%=
                                                                sp.GiaBan.toLocaleString('vi-VN') %>đ</small>
                                                    </div>
                                                </div>
                                                <span class="badge bg-danger rounded-pill px-3 py-2">Tồn: <%=
                                                        sp.SoLuongTon %></span>
                                            </li>
                                            <% }); %>
                                                <% } else { %>
                                                    <div class="text-center py-4 text-muted fst-italic">Kho hàng đang
                                                        dồi dào, không có sản phẩm nào sắp hết.</div>
                                                    <% } %>
                                </ul>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card p-4 rounded-4 shadow-sm border-0 bg-white h-100">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-fire text-warning me-2"></i>Sản
                                        phẩm bán chạy</h5>
                                </div>
                                <ul class="list-group dashboard-list">
                                    <% if(spBanChay.length> 0) { %>
                                        <% spBanChay.forEach(sp=> { %>
                                            <li class="list-group-item px-0">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-light rounded p-2 me-3"><img
                                                            src="<%= sp.HinhAnh.startsWith('http') ? sp.HinhAnh : '/images/' + sp.HinhAnh %>"
                                                            width="40" height="40" style="object-fit: contain;"></div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold text-dark text-truncate"
                                                            style="max-width: 250px;">
                                                            <%= sp.TenSP %>
                                                        </h6>
                                                    </div>
                                                </div>
                                                <span class="text-success fw-bold"><i
                                                        class="bi bi-graph-up-arrow me-1"></i>Hot</span>
                                            </li>
                                            <% }); %>
                                                <% } %>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="card p-4 rounded-4 shadow-sm border-0 bg-white">
                        <h5 class="fw-bold text-dark mb-4"><i class="bi bi-bell-fill text-primary me-2"></i>Các yêu cầu
                            chờ xử lý</h5>

                        <div class="row g-4">
                            <div class="col-md-6 border-end">
                                <h6 class="text-muted fw-bold text-uppercase mb-3">Yêu cầu Đổi/Trả</h6>
                                <% if(ycKhachHang.length> 0) { %>
                                    <% ycKhachHang.forEach(yc=> { %>
                                        <div class="d-flex justify-content-between border-bottom py-2">
                                            <div>
                                                <span class="fw-bold text-dark">
                                                    <%= yc.KhachHang ? yc.KhachHang.HoVaTen : 'Khách vô danh' %>
                                                </span>
                                                <div class="small text-muted">Loại: <%= yc.LoaiYeuCau %> - Ngày: <%=
                                                            yc.NgayYeuCau.toLocaleDateString('vi-VN') %>
                                                </div>
                                            </div>
                                            <div>
                                                <a href="/admin/doitra" class="btn btn-sm btn-outline-warning">Xử lý
                                                    ngay</a>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <p class="text-muted small fst-italic">Không có yêu cầu đổi trả mới.</p>
                                                <% } %>
                            </div>

                            <div class="col-md-6">
                                <h6 class="text-muted fw-bold text-uppercase mb-3">Đơn hàng mới chờ duyệt</h6>
                                <% if(hdChoDuyet.length> 0) { %>
                                    <% hdChoDuyet.forEach(hd=> { %>
                                        <div class="d-flex justify-content-between border-bottom py-2">
                                            <div>
                                                <span class="fw-bold text-dark">
                                                    <%= hd.KhachHang ? hd.KhachHang.HoVaTen : 'Khách vô danh' %>
                                                </span>
                                                <div class="small text-muted text-danger fw-bold">
                                                    <%= hd.TongTien.toLocaleString('vi-VN') %> đ
                                                </div>
                                            </div>
                                            <div>
                                                <a href="/admin/hoadon/chitiet/<%= hd._id %>"
                                                    class="btn btn-sm btn-outline-primary">Xem đơn</a>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <p class="text-muted small fst-italic">Chưa có đơn hàng mới nào cần
                                                    duyệt.</p>
                                                <% } %>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
    </div>
</body>

</html>