<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                
                <div class="card shadow-sm col-md-10 mx-auto border-0 rounded-4 mt-3">
                    <div class="card-header bg-warning py-3 rounded-top-4">
                        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Cập nhật Sản phẩm Tivi</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/admin/sanpham/sua/<%= sanpham._id %>" method="POST" enctype="multipart/form-data">
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Tên Tivi</label>
                                    <input type="text" class="form-control" name="TenSP" value="<%= sanpham.TenSP %>" required>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                                    <input type="number" class="form-control" name="GiaBan" value="<%= sanpham.GiaBan %>" required>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label fw-bold">Số lượng tồn</label>
                                    <input type="number" class="form-control" name="SoLuongTon" value="<%= sanpham.SoLuongTon %>">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Hãng sản xuất</label>
                                    <select class="form-select" name="HangSanXuat" required>
                                        <option value="">-- Chọn Hãng --</option>
                                        <% hangsanxuat.forEach(h => { %>
                                            <option value="<%= h._id %>" <%= sanpham.HangSanXuat.toString() == h._id.toString() ? 'selected' : '' %> >
                                                <%= h.TenHang %>
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Loại sản phẩm</label>
                                    <select class="form-select" name="LoaiSanPham" required>
                                        <option value="">-- Chọn Loại --</option>
                                        <% loaisanpham.forEach(l => { %>
                                            <option value="<%= l._id %>" <%= sanpham.LoaiSanPham.toString() == l._id.toString() ? 'selected' : '' %> >
                                                <%= l.TenLoai %>
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Thay đổi Hình ảnh</label>
                                    <input type="file" class="form-control" name="HinhAnh" accept="image/*">
                                    <div class="mt-2 d-flex align-items-center">
                                        <span class="small text-muted me-2">Ảnh hiện tại:</span>
                                        <img src="/images/<%= sanpham.HinhAnh %>" alt="Ảnh Tivi" width="50" class="img-thumbnail">
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Mô tả thêm</label>
                                <textarea class="form-control" name="MoTa" rows="3"><%= sanpham.MoTa %></textarea>
                            </div>

                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/admin/sanpham" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Hủy</a>
                                <button type="submit" class="btn btn-warning"><i class="bi bi-arrow-clockwise"></i> Cập nhật Sản Phẩm</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>