<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-info text-white py-3 rounded-top-4">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Chi tiết Phiếu Nhập Kho</h5>
                    </div>
                    <div class="card-body p-4">
                        
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p><strong>Nhà cung cấp:</strong> <%= phieunhap.NhaCungCap.TenNCC %></p>
                                <p><strong>Người lập phiếu:</strong> <%= phieunhap.NhanVien.HoVaTen %></p>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <p><strong>Ngày nhập:</strong> <%= phieunhap.NgayNhap.toLocaleString('vi-VN') %></p>
                            </div>
                        </div>

                        <table class="table table-bordered align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th width="10%">Hình ảnh</th>
                                    <th class="text-start">Tên Tivi</th>
                                    <th>Số lượng nhập</th>
                                    <th>Đơn giá nhập</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% phieunhap.ChiTietNhap.forEach(ct => { %>
                                    <tr>
                                        <td>
                                            <img src="/images/<%= ct.SanPham.HinhAnh %>" alt="Tivi" width="50" class="img-thumbnail">
                                        </td>
                                        <td class="text-start fw-bold"><%= ct.SanPham.TenSP %></td>
                                        <td><span class="badge bg-success fs-6">+ <%= ct.SoLuong %></span></td>
                                        <td><%= ct.DonGiaNhap.toLocaleString('vi-VN') %> đ</td>
                                        <td class="text-danger fw-bold"><%= (ct.DonGiaNhap * ct.SoLuong).toLocaleString('vi-VN') %> đ</td>
                                    </tr>
                                <% }); %>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" class="text-end fw-bold fs-5">Tổng vốn nhập hàng:</td>
                                    <td class="text-danger fw-bold fs-4"><%= phieunhap.TongTienNhap.toLocaleString('vi-VN') %> đ</td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="mt-4 text-end">
                            <a href="/admin/nhaphang" class="btn btn-secondary"><i class="bi bi-arrow-return-left"></i> Quay lại</a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>