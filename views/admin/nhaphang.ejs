<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid bg-white p-4 rounded-4 shadow-sm">
                
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                    <h3 class="fw-bold mb-0"><i class="bi bi-box-arrow-in-down"></i> Lịch sử Nhập Hàng</h3>
                    <a href="/admin/nhaphang/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo phiếu nhập mới</a>
                </div>

                <table class="table table-bordered table-hover align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            <th width="5%">#</th>
                            <th class="text-start">Hãng sản xuất (Nguồn nhập)</th>
                            <th>Ngày nhập</th>
                            <th>Người nhập</th>
                            <th>Tổng tiền gốc</th>
                            <th width="10%">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = 1; %>
                        <% nhaphang.forEach(pn => { %>
                            <tr>
                                <th><%= stt++ %></th>
                                
                                <td class="text-start fw-bold text-primary">
                                    <% 
                                        let tenNguonNhap = 'N/A';
                                        if (pn.NhaCungCap) {
                                            // Check xem có thuộc tính TenHang hay TenNCC
                                            tenNguonNhap = pn.NhaCungCap.TenHang || pn.NhaCungCap.TenNCC || 'Đã đổi tên hãng';
                                        } 
                                    %>
                                    <%= tenNguonNhap %>
                                </td>
                                
                                <td><%= pn.NgayNhap.toLocaleString('vi-VN') %></td>
                                <td class="small"><%= pn.NhanVien ? pn.NhanVien.HoVaTen : '-' %></td>
                                <td class="text-danger fw-bold"><%= pn.TongTienNhap.toLocaleString('vi-VN') %> đ</td>
                                <td>
                                    <a href="/admin/nhaphang/chitiet/<%= pn._id %>" class="btn btn-sm btn-info text-white" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                        
                        <% if(nhaphang.length === 0) { %>
                            <tr><td colspan="6" class="py-4 text-muted fst-italic">Chưa có dữ liệu phiếu nhập hàng nào.</td></tr>
                        <% } %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</body>
</html>