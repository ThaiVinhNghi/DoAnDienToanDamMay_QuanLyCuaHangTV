<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body, html { height: 100%; margin: 0; background-color: #f8f9fa; }
        .sidebar { width: 280px; min-height: 100vh; }
    </style>
</head>

<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid bg-white p-4 rounded-4 shadow-sm">

                <h3 class="fw-bold mb-4 border-bottom pb-2 text-primary">
                    <i class="bi bi-receipt-cutoff"></i> Quản lý Đơn hàng
                </h3>

                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th width="5%">#</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th>Người duyệt</th>
                            <th width="15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt=1; %>
                        <% hoadon.forEach(hd=> { %>
                            <tr>
                                <th class="text-center"><%= stt++ %></th>
                                <td class="fw-bold text-primary">
                                    <%= hd.KhachHang ? hd.KhachHang.HoVaTen : 'Khách vô danh' %>
                                </td>
                                <td class="text-center">
                                    <%= hd.NgayLap.toLocaleString('vi-VN') %>
                                </td>
                                <td class="text-danger fw-bold text-end">
                                    <%= hd.TongTien.toLocaleString('vi-VN') %> đ
                                </td>

                                <td class="text-center">
                                    <% if(hd.HinhThucThanhToan==='Trả góp' ) { %>
                                        <span class="badge bg-primary text-white"><i class="bi bi-credit-card"></i> Trả góp</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary text-white"><i class="bi bi-cash-coin"></i> Trả hết</span>
                                    <% } %>
                                </td>

                                <td class="text-center">
                                    <% if(hd.TrangThai==='Chờ duyệt' ) { %>
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                    <% } else if(hd.TrangThai==='Đã duyệt' ) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                                    <% } else { %>
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                    <% } %>
                                </td>
                                
                                <td class="text-center small text-muted">
                                    <%= hd.NhanVienDuyet ? hd.NhanVienDuyet.HoVaTen : '-' %>
                                </td>
                                
                                <td class="text-center d-flex justify-content-center gap-1">
                                    
                                    <a href="/admin/hoadon/chitiet/<%= hd._id %>" class="btn btn-sm btn-info text-white" title="Xem chi tiết"><i class="bi bi-eye"></i></a>

                                    <% if(hd.TrangThai==='Chờ duyệt' ) { %>
                                        <a href="/admin/hoadon/duyet/<%= hd._id %>" class="btn btn-sm btn-success" title="Duyệt đơn"><i class="bi bi-check-lg"></i></a>
                                        <a href="/admin/hoadon/huy/<%= hd._id %>" class="btn btn-sm btn-danger" title="Hủy đơn" onclick="return confirm('Xác nhận HỦY đơn hàng này?');"><i class="bi bi-x-lg"></i></a>
                                    
                                    <% } else if(hd.TrangThai==='Đã duyệt' ) { %>
                                        <a href="/admin/hoadon/in/<%= hd._id %>" class="btn btn-sm btn-dark fw-bold shadow-sm" target="_blank" title="In Hóa Đơn">
                                            <i class="bi bi-printer"></i> In
                                        </a>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>

                        <% if(hoadon.length===0) { %>
                            <tr>
                                <td colspan="8" class="text-center py-4">Chưa có đơn hàng nào!</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</body>

</html>