<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid bg-white p-4 rounded-4 shadow-sm">
                
                <h3 class="fw-bold mb-4 border-bottom pb-2 text-primary"><i class="bi bi-bank"></i> Sổ Theo Dõi Trả Góp</h3>

                <table class="table table-bordered table-hover align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            <th>Khách hàng</th>
                            <th>Tổng đơn hàng</th>
                            <th>Mỗi tháng đóng</th>
                            <th class="text-primary">Tiến độ</th>
                            <th class="text-warning text-dark">Nhắc nhở</th>
                            <th>Trạng thái</th>
                            <th width="15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tragop.forEach(tg => { %>
                            <tr>
                                <td class="fw-bold"><%= tg.KhachHang ? tg.KhachHang.HoVaTen : 'Khách vô danh' %></td>
                                <td><%= tg.HoaDon ? tg.HoaDon.TongTien.toLocaleString('vi-VN') : 0 %> đ</td>
                                
                                <td class="text-danger fw-bold"><%= Math.round(tg.TienTraMoiThang).toLocaleString('vi-VN') %> đ</td>
                                
                                <td class="fw-bold text-primary fs-5"><%= tg.SoThangDaTra %> / <%= tg.SoThang %></td>
                                
                                <td class="fw-bold text-danger fs-5">
                                    <%= tg.SoLanNhacNho || 0 %> <span class="fs-6 text-muted">/ 3</span>
                                </td>
                                
                                <td>
                                    <% if(tg.TrangThai === 'Đã tất toán') { %>
                                        <span class="badge bg-success px-3 py-2"><i class="bi bi-shield-check"></i> Đã tất toán</span>
                                    <% } else if(tg.TrangThai === 'Nợ xấu') { %>
                                        <span class="badge bg-danger px-3 py-2 heartbeat"><i class="bi bi-exclamation-triangle-fill"></i> Nợ xấu</span>
                                    <% } else if(tg.TrangThai === 'Quá hạn') { %>
                                        <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-bell-fill"></i> Quá hạn</span>
                                    <% } else { %>
                                        <span class="badge bg-primary px-3 py-2">Đang trả</span>
                                    <% } %>
                                </td>
                                
                                <td>
                                    <% if(tg.TrangThai !== 'Đã tất toán') { %>
                                        <div class="d-flex flex-column gap-2">
                                            <form action="/admin/tragop/thutien/<%= tg._id %>" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-success w-100 fw-bold" onclick="return confirm(`Xác nhận thu <%= Math.round(tg.TienTraMoiThang).toLocaleString('vi-VN') %> đ của khách này?`);">
                                                    <i class="bi bi-cash"></i> Thu kỳ <%= tg.SoThangDaTra + 1 %>
                                                </button>
                                            </form>

                                            <form action="/admin/tragop/tattoan/<%= tg._id %>" method="POST" class="m-0">
                                                <% let soTienConLai = Math.round((tg.SoThang - tg.SoThangDaTra) * tg.TienTraMoiThang); %>
                                                <button type="submit" class="btn btn-sm btn-info w-100 fw-bold text-white" onclick="return confirm(`Xác nhận khách thanh toán HẾT khoản nợ còn lại là: <%= soTienConLai.toLocaleString('vi-VN') %> đ?`);">
                                                    <i class="bi bi-piggy-bank-fill"></i> Tất toán
                                                </button>
                                            </form>

                                            <% if(tg.TrangThai !== 'Nợ xấu') { %>
                                                <a href="/admin/tragop/nhacnho/<%= tg._id %>" class="btn btn-sm btn-warning w-100 fw-bold text-dark" onclick="return confirm('Gửi nhắc nhở cho khách này? (Quá 3 lần sẽ thành Nợ Xấu)');">
                                                    <i class="bi bi-bell-fill"></i> Nhắc nhở
                                                </a>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-secondary w-100" disabled><i class="bi bi-check2-all"></i> Hoàn thành</button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</body>
</html>