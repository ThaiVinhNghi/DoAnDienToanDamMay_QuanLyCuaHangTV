<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-info text-white py-3 rounded-top-4 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Chi tiết Hóa đơn</h5>
                        <span class="badge bg-light text-dark fs-6"><%= hoadon.TrangThai %></span>
                    </div>
                    <div class="card-body p-4">
                        
                        <h6 class="text-primary border-bottom pb-2 mb-3">Thông tin Người nhận & Thanh toán</h6>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p><strong>Họ và tên:</strong> <%= hoadon.KhachHang.HoVaTen %></p>
                                <p><strong>Số điện thoại:</strong> <%= hoadon.KhachHang.SoDienThoai %></p>
                                
                                <p class="mb-0"><strong>Hình thức thanh toán:</strong> 
                                    <% if(hoadon.HinhThucThanhToan === 'Trả góp') { %>
                                        <span class="text-primary fw-bold"><i class="bi bi-credit-card"></i> Mua Trả Góp</span>
                                    <% } else { %>
                                        <span class="text-success fw-bold"><i class="bi bi-cash-coin"></i> Trả thẳng khi nhận hàng</span>
                                    <% } %>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Địa chỉ giao:</strong> <%= hoadon.KhachHang.DiaChi %></p>
                                <p><strong>Ngày đặt hàng:</strong> <%= hoadon.NgayLap.toLocaleString('vi-VN') %></p>
                            </div>
                        </div>

                        <h6 class="text-primary border-bottom pb-2 mb-3">Danh sách Sản phẩm</h6>
                        <table class="table table-bordered align-middle text-center">
                            <thead class="table-light">
                                <tr>
                                    <th width="10%">Hình ảnh</th>
                                    <th class="text-start">Tên Tivi</th>
                                    <th>Đơn giá</th>
                                    <th width="10%">Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% hoadon.ChiTietHoaDon.forEach(ct => { %>
                                    <tr>
                                        <td>
                                            <img src="/images/<%= ct.SanPham.HinhAnh %>" alt="Tivi" width="50" class="img-thumbnail">
                                        </td>
                                        <td class="text-start fw-bold"><%= ct.SanPham.TenSP %></td>
                                        <td><%= ct.DonGiaBan.toLocaleString('vi-VN') %> đ</td>
                                        <td><%= ct.SoLuong %></td>
                                        <td class="text-danger fw-bold"><%= (ct.DonGiaBan * ct.SoLuong).toLocaleString('vi-VN') %> đ</td>
                                    </tr>
                                <% }); %>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" class="text-end fw-bold fs-5">Tổng cộng đơn hàng:</td>
                                    <td class="text-danger fw-bold fs-4"><%= hoadon.TongTien.toLocaleString('vi-VN') %> đ</td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="mt-4 text-end">
                            <a href="/admin/hoadon" class="btn btn-secondary"><i class="bi bi-arrow-return-left"></i> Quay lại</a>
                            <% if(hoadon.TrangThai === 'Chờ duyệt') { %>
                                <a href="/admin/hoadon/duyet/<%= hoadon._id %>" class="btn btn-success"><i class="bi bi-check-lg"></i> Phê duyệt đơn hàng</a>
                            <% } %>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>