<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                
                <div class="card shadow-sm col-md-10 mx-auto border-0 rounded-4 mt-3">
                    <div class="card-header bg-primary text-white py-3 rounded-top-4">
                        <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Thêm Sản phẩm Tivi mới</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/admin/sanpham/them" method="POST" enctype="multipart/form-data">
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Tên Tivi</label>
                                    <input type="text" class="form-control" name="TenSP" required>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                                    <input type="number" class="form-control" name="GiaBan" value="0" required>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label fw-bold">Số lượng tồn</label>
                                    <input type="number" class="form-control" name="SoLuongTon" value="0">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Hãng sản xuất</label>
                                    <select class="form-select" name="HangSanXuat" required>
                                        <option value="">-- Chọn Hãng --</option>
                                        <% hangsanxuat.forEach(h => { %>
                                            <option value="<%= h._id %>"><%= h.TenHang %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Loại sản phẩm</label>
                                    <select class="form-select" name="LoaiSanPham" required>
                                        <option value="">-- Chọn Loại --</option>
                                        <% loaisanpham.forEach(l => { %>
                                            <option value="<%= l._id %>"><%= l.TenLoai %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Hình ảnh Tivi</label>
                                    <input type="file" class="form-control" name="HinhAnh" accept="image/*" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Mô tả thêm</label>
                                <textarea class="form-control" name="MoTa" rows="3"></textarea>
                            </div>

                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/admin/sanpham" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Hủy</a>
                                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Lưu Sản Phẩm</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>