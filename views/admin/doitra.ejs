<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f3f6f9; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid bg-white p-4 rounded-4 shadow-sm">
                
                <h3 class="fw-bold mb-4 border-bottom pb-2 text-primary">
                    <i class="bi bi-arrow-repeat me-2"></i> Quản Lý Yêu Cầu Đổi/Trả
                </h3>

                <table class="table table-bordered table-hover align-middle text-center">
                    <thead>
                        <tr>
                            <th>Khách hàng</th>
                            <th>Đơn cũ (Cần trả)</th>
                            <th>Sản phẩm Đổi lấy</th>
                            <th>Chênh lệch Tiền</th>
                            <th>Lý do</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dsDoiTra.forEach(dt => { %>
                            <tr>
                                <td class="fw-bold text-dark"><%= dt.KhachHang.HoVaTen %></td>
                                <td>
                                    Đơn #<%= dt.HoaDon._id.toString().slice(-4).toUpperCase() %><br>
                                    <span class="text-danger fw-bold"><%= dt.HoaDon.TongTien.toLocaleString('vi-VN') %> đ</span>
                                </td>

                                <td>
                                    <% if(dt.LoaiYeuCau === 'Đổi hàng' && dt.SanPhamMoi.length > 0) { %>
                                        <span class="text-primary fw-bold"><%= dt.SanPhamMoi[0].SanPham.TenSP %></span><br>
                                        <span class="text-danger"><%= dt.SanPhamMoi[0].SanPham.GiaBan.toLocaleString('vi-VN') %> đ</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary px-3 py-2">Chỉ Trả hàng</span>
                                    <% } %>
                                </td>

                                <td class="fw-bold">
                                    <% if(dt.LoaiYeuCau === 'Trả hàng') { %>
                                        <span class="text-success"><i class="bi bi-arrow-return-left"></i> Hoàn lại: <%= dt.HoaDon.TongTien.toLocaleString('vi-VN') %> đ</span>
                                    <% } else if(dt.LoaiYeuCau === 'Đổi hàng' && dt.SanPhamMoi.length > 0) { 
                                        let chenhLech = dt.SanPhamMoi[0].SanPham.GiaBan - dt.HoaDon.TongTien;
                                        if(chenhLech > 0) { %>
                                            <span class="text-danger"><i class="bi bi-plus-circle"></i> Khách bù: <%= chenhLech.toLocaleString('vi-VN') %> đ</span>
                                        <% } else if(chenhLech < 0) { %>
                                            <span class="text-success"><i class="bi bi-dash-circle"></i> Hoàn lại: <%= Math.abs(chenhLech).toLocaleString('vi-VN') %> đ</span>
                                        <% } else { %>
                                            <span class="text-muted">Vừa đủ tiền</span>
                                        <% } 
                                    } %>
                                </td>

                                <td><%= dt.LyDo %></td>

                                <td>
                                    <% if(dt.TrangThai === 'Chờ xử lý') { %>
                                        <form action="/admin/doitra/duyet/<%= dt._id %>" method="POST" class="m-0">
                                            <button class="btn btn-sm btn-success fw-bold w-100" onclick="return confirm('Duyệt & Cập nhật lại kho hàng?');">
                                                <i class="bi bi-check-circle"></i> Duyệt <%= dt.LoaiYeuCau %>
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span class="badge bg-success px-3 py-2"><i class="bi bi-check2-all"></i> <%= dt.TrangThai %></span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>