<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body, html { height: 100%; margin: 0; background-color: #f8f9fa; }
        .sidebar { width: 280px; min-height: 100vh; }
    </style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                
                <div class="card shadow-sm col-md-8 mx-auto border-0 rounded-4 mt-3">
                    <div class="card-header bg-primary text-white py-3 rounded-top-4">
                        <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Thêm Hãng sản xuất</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/admin/hangsanxuat/them" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên Hãng</label>
                                <input type="text" class="form-control" name="TenHang" placeholder="Vd: Sony, Samsung, LG..." required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Quốc gia</label>
                                <input type="text" class="form-control" name="QuocGia" placeholder="Vd: Nhật Bản, Hàn Quốc...">
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Lưu lại</button>
                                <a href="/admin/hangsanxuat" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Hủy</a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>