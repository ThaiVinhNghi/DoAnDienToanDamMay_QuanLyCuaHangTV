<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>body, html { height: 100%; margin: 0; background-color: #f8f9fa; } .sidebar { width: 280px; min-height: 100vh; }</style>
</head>
<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

        <div class="flex-grow-1 p-4 overflow-auto">
            <div class="container-fluid">
                <div class="card shadow-sm col-md-10 mx-auto border-0 rounded-4 mt-3">
                    <div class="card-header bg-primary text-white py-3 rounded-top-4">
                        <h5 class="mb-0"><i class="bi bi-person-plus"></i> Thêm Khách hàng mới</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/admin/khachhang/them" method="POST">
                            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">Thông tin liên hệ</h6>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Họ và tên</label>
                                    <input type="text" class="form-control" name="HoVaTen" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Số điện thoại</label>
                                    <input type="text" class="form-control" name="SoDienThoai" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="email" class="form-control" name="Email">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Địa chỉ giao hàng</label>
                                <input type="text" class="form-control" name="DiaChi" required>
                            </div>

                            <h6 class="text-primary fw-bold border-bottom pb-2 mb-3">Thông tin Đăng nhập</h6>
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="form-label fw-bold">Tên đăng nhập</label>
                                    <input type="text" class="form-control" name="TenDangNhap" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label fw-bold">Mật khẩu</label>
                                    <input type="password" class="form-control" name="MatKhau" required>
                                </div>
                            </div>
                            
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/admin/khachhang" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Hủy</a>
                                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Lưu Tài Khoản</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>