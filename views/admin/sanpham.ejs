<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body,
        html {
            height: 100%;
            margin: 0;
            background-color: #f8f9fa;
        }

        .sidebar {
            width: 280px;
            min-height: 100vh;
        }
    </style>
</head>

<body>
    <div class="d-flex h-100">
        <%- include('sidebar') %>

            <div class="flex-grow-1 p-4 overflow-auto">
                <div class="container-fluid bg-white p-4 rounded-4 shadow-sm">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="fw-bold mb-0">Danh sách Sản phẩm Tivi</h3>
                        <a href="/admin/sanpham/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm
                            Tivi</a>
                    </div>

                    <table class="table table-bordered table-hover mt-3 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th width="5%" class="text-center">#</th>
                                <th width="10%" class="text-center">Hình ảnh</th>
                                <th>Tên Tivi</th>
                                <th>Giá bán</th>
                                <th>Hãng / Loại</th>
                                <th width="10%" class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                                <% sanpham.forEach(sp=> { %>
                                    <tr>
                                        <th class="text-center">
                                            <%= stt++ %>
                                        </th>
                                        <td class="text-center">
                                            <img src="/images/<%= sp.HinhAnh %>" alt="Lỗi ảnh" width="60"
                                                class="img-thumbnail">
                                        </td>
                                        <td class="fw-bold text-primary">
                                            <%= sp.TenSP %>
                                        </td>
                                        <td class="text-danger fw-bold">
                                            <%= sp.GiaBan.toLocaleString('vi-VN') %> đ
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">
                                                <%= sp.HangSanXuat ? sp.HangSanXuat.TenHang : 'N/A' %>
                                            </span>
                                            <span class="badge bg-info text-dark">
                                                <%= sp.LoaiSanPham ? sp.LoaiSanPham.TenLoai : 'N/A' %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <a href="/admin/sanpham/sua/<%= sp._id %>" class="btn btn-sm btn-warning"><i
                                                    class="bi bi-pencil-square"></i></a>
                                            <a href="/admin/sanpham/xoa/<%= sp._id %>" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Bạn có chắc muốn xóa Tivi này?');"><i
                                                    class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>

                </div>
            </div>
    </div>
</body>

</html>