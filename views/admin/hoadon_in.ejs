<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <title>In Hóa Đơn - <%= hoadon._id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Times New Roman', serif; background-color: #f0f0f0; color: #000; }
        
        /* Cấu hình khung giấy A4 */
        .a4-page {
            width: 21cm;
            min-height: 29.7cm;
            padding: 2cm;
            margin: 1cm auto;
            background: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        /* Ẩn các nút bấm khi in ra giấy thực tế */
        @media print {
            body { background-color: #fff; margin: 0; padding: 0; }
            .a4-page { width: 100%; margin: 0; padding: 0; box-shadow: none; }
            .no-print { display: none !important; }
        }

        .table-bordered th, .table-bordered td { border: 1px solid #000 !important; }
        .table th { background-color: #f8f9fa !important; -webkit-print-color-adjust: exact; }
    </style>
</head>
<body>

    <div class="text-center py-3 bg-dark no-print position-sticky top-0 shadow" style="z-index: 100;">
        <button onclick="window.print()" class="btn btn-primary fw-bold px-4 me-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-printer-fill me-1" viewBox="0 0 16 16"><path d="M5 1a2 2 0 0 0-2 2v1h10V3a2 2 0 0 0-2-2H5zm6 8H5a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1z"/><path d="M0 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-1v-2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2H2a2 2 0 0 1-2-2V7zm2.5 1a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/></svg> 
            In Hóa Đơn (PDF)
        </button>
       <button onclick="window.close()" class="btn btn-secondary fw-bold px-4">Đóng cửa sổ</button>
    </div>

    <div class="a4-page">
        <div class="row border-bottom border-2 border-dark pb-3 mb-4">
            <div class="col-8">
                <h3 class="fw-bold text-uppercase mb-1">Cửa Hàng Tivi TVN</h3>
                <p class="mb-1"><strong>Địa chỉ:</strong> 54/98 Đường Trần Quang Khải, P. Mỹ Thới, TP. Long Xuyên</p>
                <p class="mb-0"><strong>Hotline:</strong> 0931.082.845 - <strong>Email:</strong> hotro@tivin.com</p>
            </div>
            <div class="col-4 text-end">
                <h2 class="text-danger fw-bold text-uppercase mb-0">Hóa Đơn</h2>
                <p class="text-muted mb-0">Mã: #<%= hoadon._id.toString().substring(18, 24).toUpperCase() %></p>
            </div>
        </div>

        <h4 class="text-center fw-bold text-uppercase mb-4">Hóa Đơn Mua Hàng</h4>
        <div class="row mb-4">
            <div class="col-6">
                <p class="mb-1"><strong>Khách hàng:</strong> <%= hoadon.KhachHang.HoVaTen %></p>
                <p class="mb-1"><strong>Số điện thoại:</strong> <%= hoadon.KhachHang.SoDienThoai %></p>
                <p class="mb-0"><strong>Địa chỉ giao:</strong> <%= hoadon.KhachHang.DiaChi %></p>
            </div>
            <div class="col-6 text-end">
                <p class="mb-1"><strong>Ngày lập:</strong> <%= hoadon.NgayLap.toLocaleDateString('vi-VN') %></p>
                <p class="mb-0"><strong>Thanh toán:</strong> <%= hoadon.HinhThucThanhToan %></p>
            </div>
        </div>

        <table class="table table-bordered text-center align-middle mb-4">
            <thead>
                <tr>
                    <th width="5%">STT</th>
                    <th width="45%" class="text-start">Tên sản phẩm</th>
                    <th width="10%">Số lượng</th>
                    <th width="20%">Đơn giá</th>
                    <th width="20%">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                <% let stt = 1; %>
                <% hoadon.ChiTietHoaDon.forEach(ct => { %>
                    <tr>
                        <td><%= stt++ %></td>
                        <td class="text-start"><%= ct.SanPham ? ct.SanPham.TenSP : 'Sản phẩm không tồn tại' %></td>
                        <td><%= ct.SoLuong %></td>
                        <td><%= ct.DonGiaBan.toLocaleString('vi-VN') %> đ</td>
                        <td class="fw-bold"><%= (ct.DonGiaBan * ct.SoLuong).toLocaleString('vi-VN') %> đ</td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="row mb-5">
            <div class="col-7">
                <p class="fst-italic text-muted">*Ghi chú: Giá trên đã bao gồm thuế GTGT (VAT).</p>
                <p class="fst-italic text-muted">*Sản phẩm được bảo hành chính hãng 24 tháng kể từ ngày mua.</p>
            </div>
            <div class="col-5">
                <table class="table table-borderless">
                    <tr>
                        <td class="text-end fw-bold fs-5">TỔNG CỘNG:</td>
                        <td class="text-end fw-bold fs-5 text-danger"><%= hoadon.TongTien.toLocaleString('vi-VN') %> đ</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row text-center mt-5 pt-4">
            <div class="col-6">
                <h6 class="fw-bold">Người Mua Hàng</h6>
                <p class="fst-italic">(Ký, ghi rõ họ tên)</p>
            </div>
            <div class="col-6">
                <h6 class="fw-bold">Người Bán Hàng</h6>
                <p class="fst-italic">(Ký, đóng dấu)</p>
            </div>
        </div>
        
    </div>

    <script>
        window.onload = function() {
            setTimeout(() => {
                window.print();
            }, 500); // Chờ 0.5s cho CSS load hết rồi mở hộp in
        };
    </script>
</body>
</html>