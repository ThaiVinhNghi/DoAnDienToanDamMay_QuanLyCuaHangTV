<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#eff6ff', 100: '#dbeafe', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' },
                        facebook: '#1877F2', // Thêm màu chuẩn của Facebook
                        'facebook-hover': '#166FE5'
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen bg-slate-50 flex flex-col font-sans">

    <%- include('navbar') %>

        <div class="flex-grow flex items-center justify-center p-4 mt-8 mb-12">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden flex max-w-4xl w-full">

                <div class="hidden md:block md:w-1/2 relative bg-brand-600">
                    <img src="/images/login.jpg" class="absolute inset-0 w-full h-full object-cover opacity-60"
                        alt="Đăng nhập TVN Store">
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-brand-900/80 to-transparent flex flex-col justify-end p-10 text-white">
                        <h3 class="text-3xl font-bold mb-2">Chào mừng trở lại!</h3>
                        <p class="text-brand-100">Đăng nhập để xem các ưu đãi độc quyền dành riêng cho bạn tại TVN
                            Store.</p>
                    </div>
                </div>

                <div class="w-full md:w-1/2 p-8 sm:p-12">
                    <div class="text-center mb-8">
                        <div
                            class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-50 text-brand-600 mb-4 shadow-sm">
                            <i class="bi bi-person-fill text-3xl"></i>
                        </div>
                        <h2 class="text-2xl font-extrabold text-slate-900">Đăng Nhập</h2>
                        <p class="text-sm text-slate-500 mt-1">Vui lòng đăng nhập để tiếp tục mua sắm</p>
                    </div>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-lg flex items-center">
                            <i class="bi bi-exclamation-circle-fill text-red-500 mr-3 text-lg"></i>
                            <p class="text-sm text-red-700 font-semibold">
                                <%= error %>
                            </p>
                        </div>
                        <% } %>

                            <form action="/dangnhap" method="POST" class="space-y-5">
                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Tên đăng nhập</label>
                                    <div class="relative">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-person text-slate-400"></i>
                                        </div>
                                        <input type="text" name="TenDangNhap" required autofocus
                                            class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                            placeholder="Nhập tên tài khoản...">
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-slate-700 mb-1">Mật khẩu</label>
                                    <div class="relative">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-lock text-slate-400"></i>
                                        </div>
                                        <input type="password" name="MatKhau" required
                                            class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors outline-none text-slate-700"
                                            placeholder="••••••••">
                                    </div>
                                </div>

                                <div class="flex items-center justify-end pt-2">
                                    <a href="/quenmatkhau"
                                        class="text-sm font-semibold text-brand-600 hover:text-brand-500 transition-colors">
                                        Quên mật khẩu?
                                    </a>
                                </div>

                                <button type="submit"
                                    class="w-full bg-brand-600 hover:bg-brand-700 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-brand-500/30 transition-all hover:-translate-y-0.5 mt-4">
                                    ĐĂNG NHẬP
                                </button>
                            </form>

                            <div class="mt-6">
                                <div class="relative mb-6">
                                    <div class="absolute inset-0 flex items-center">
                                        <div class="w-full border-t border-slate-200"></div>
                                    </div>
                                    <div class="relative flex justify-center text-sm">
                                        <span class="px-3 bg-white text-slate-500 font-medium">Hoặc tiếp tục với</span>
                                    </div>
                                </div>

                                <a href="/auth/facebook"
                                    class="w-full flex items-center justify-center bg-facebook hover:bg-facebook-hover text-white font-bold py-3.5 rounded-xl shadow-lg shadow-blue-500/30 transition-all hover:-translate-y-0.5">
                                    <i class="bi bi-facebook text-xl mr-2"></i> Đăng nhập bằng Facebook
                                </a>
                            </div>

                            <p class="mt-8 text-center text-sm text-slate-600">
                                Chưa có tài khoản?
                                <a href="/dangky"
                                    class="font-bold text-brand-600 hover:text-brand-700 transition-colors">Đăng ký
                                    ngay</a>
                            </p>
                </div>
            </div>
        </div>

        <%- include('footer') %>
</body>

</html>