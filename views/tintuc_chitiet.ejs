<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#fff0f0', 100: '#fecaca', 200: '#fca5a5', 500: '#dc2626', 600: '#b91c1c', 700: '#991b1b', 800: '#7f1d1d' } }
                }
            }
        }
    </script>
</head>

<body class="flex flex-col min-h-screen bg-slate-50 font-sans text-slate-800">

    <%- include('navbar') %>

        <div class="container mx-auto px-4 mt-8 mb-16 flex-grow flex justify-center">
            <div class="w-full max-w-4xl">

                <a href="/tintuc"
                    class="inline-flex items-center text-slate-500 hover:text-brand-600 font-bold mb-6 transition-colors group">
                    <i class="bi bi-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i> Quay lại Bảng
                    tin
                </a>

                <article class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">

                    <% let imgSrc=tin.HinhAnh.startsWith('http') ? tin.HinhAnh : '/images/' + tin.HinhAnh; %>
                        <div class="w-full h-[300px] md:h-[450px] overflow-hidden relative bg-slate-900">
                            <img src="<%= imgSrc %>" class="absolute inset-0 w-full h-full object-cover opacity-90"
                                alt="<%= tin.TieuDe %>">
                        </div>

                        <div class="p-6 md:p-10 lg:p-12">
                            <div
                                class="flex items-center text-sm font-bold text-brand-600 bg-brand-50 px-4 py-2 rounded-xl w-fit mb-6 border border-brand-100 shadow-sm">
                                <i class="bi bi-calendar-event mr-2 text-lg"></i>
                                <%= new Date(tin.NgayDang).toLocaleDateString('vi-VN') %>
                            </div>

                            <h1
                                class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
                                <%= tin.TieuDe %>
                            </h1>

                            <p
                                class="text-lg md:text-xl font-semibold text-slate-600 mb-8 pb-8 border-b border-slate-100 leading-relaxed">
                                <%= tin.TomTat %>
                            </p>

                            <div class="text-slate-700 text-lg leading-loose whitespace-pre-line font-medium">
                                <%- tin.NoiDung %>
                            </div>

                        </div>
                </article>

                <div
                    class="mt-8 flex items-center justify-between bg-white rounded-2xl p-6 border border-slate-100 shadow-sm">
                    <span class="font-bold text-slate-700">Chia sẻ bài viết này:</span>
                    <div class="flex gap-3">
                        <button
                            class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 hover:bg-blue-600 hover:text-white flex items-center justify-center transition-colors"><i
                                class="bi bi-facebook text-lg"></i></button>
                        <button
                            class="w-10 h-10 rounded-full bg-sky-100 text-sky-500 hover:bg-sky-500 hover:text-white flex items-center justify-center transition-colors"><i
                                class="bi bi-twitter text-lg"></i></button>
                        <button
                            class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 hover:bg-slate-600 hover:text-white flex items-center justify-center transition-colors"
                            onclick="navigator.clipboard.writeText(window.location.href); alert('Đã copy link!');"><i
                                class="bi bi-link-45deg text-lg"></i></button>
                    </div>
                </div>

            </div>
        </div>

        <%- include('footer') %>
</body>

</html>